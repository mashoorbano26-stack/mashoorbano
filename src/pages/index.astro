---
// src/pages/index.astro
export const prerender = false;  // SSR — required so Astro.locals (Supabase) is available
import SEOHead from '@/components/layout/SEOHead.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import Hero from '@/components/sections/Hero.astro';
import SocialProofBar from '@/components/sections/SocialProofBar.astro';
import Services from '@/components/sections/Services.astro';
import StartupStory from '@/components/sections/StartupStory.astro';
import Packages from '@/components/sections/Packages.astro';
import Testimonials from '@/components/sections/Testimonials.astro';
import ContactSection from '@/components/sections/ContactSection.astro';
import '@/styles/global.css';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'MashoorBano',
  url: 'https://MashoorBano.com',
  description: 'Digital agency — websites, merch, content, Meta ads, Google ads for Indian brands.',
  telephone: '+917814718340',
  areaServed: 'IN',
  address: { '@type': 'PostalAddress', addressCountry: 'IN' },
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <SEOHead
      title="MashoorBano — Digital Agency India"
      description="Websites. Merch. Content. Meta Ads. Google Ads. All under one roof for brands that refuse to blend in."
      keywords="digital agency india, website design, meta ads, google ads, brand identity, MashoorBano"
      jsonLd={jsonLd}
    />
  </head>
  <body style="background:#F7F5F2; overflow-x:hidden;">

    <Navbar />

    <main>
      <Hero />
      <SocialProofBar />
      <Services />
      <StartupStory />
      <Packages />
      <Testimonials />
      <ContactSection />
    </main>

    <Footer />

    <script>
      /* Scroll reveal */
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    </script>

  </body>
</html>
