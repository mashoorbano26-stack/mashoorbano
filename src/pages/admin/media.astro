---
export const prerender = false;
import { makeServerClient, getAdmin } from '@/lib/supabase';
const supabase = makeServerClient(Astro.cookies);
const supabaseAdmin = getAdmin(Astro.locals);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/admin/login');

const bucket = Astro.url.searchParams.get('bucket') ?? 'portfolio';
const BUCKETS = ['hero','portfolio','testimonials','team','blog','og'];

let files: any[] = [];
let error = '';
try {
  const { data, error: e } = await supabaseAdmin.storage.from(bucket).list('', { limit: 100, sortBy: { column: 'created_at', order: 'desc' } });
  if (e) error = e.message;
  else files = (data ?? []).filter(f => f.name !== '.emptyFolderPlaceholder');
} catch(e: any) { error = e.message; }

const PUBLIC_URL = import.meta.env.PUBLIC_SUPABASE_URL + '/storage/v1/object/public/';
---
<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"/><title>Media — MashoorBano Admin</title><meta name="robots" content="noindex,nofollow"/><link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet"/>
<style>*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}body{background:#F7F5F2;color:#1A1A1A;font-family:Inter,sans-serif;min-height:100vh;display:flex}aside{width:220px;min-height:100vh;background:#fff;border-right:1px solid #E5E0D8;display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto;flex-shrink:0}.logo{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1rem;padding:1.25rem 1rem;border-bottom:1px solid #E5E0D8}.logo span{color:#FF3B00}nav a{display:block;padding:.45rem 1rem;color:#888;font-size:.8125rem;text-decoration:none;border-left:2px solid transparent;transition:all .15s}nav a:hover{color:#1A1A1A;background:#F7F5F2}nav a.active{color:#FF3B00;border-left-color:#FF3B00;background:#fff5f3}.sf{padding:.75rem 1rem;border-top:1px solid #E5E0D8;margin-top:auto}.sf a{font-size:.75rem;color:#888;text-decoration:none}main{flex:1;padding:2rem}h1{font-family:'Space Grotesk',sans-serif;font-size:1.375rem;font-weight:700;margin-bottom:.25rem}.sub{color:#888;font-size:.8125rem;margin-bottom:1.5rem}.buckets{display:flex;gap:.5rem;margin-bottom:2rem;flex-wrap:wrap}.bucket-btn{padding:.375rem .875rem;border-radius:999px;font-size:.75rem;font-weight:600;text-decoration:none;border:1.5px solid #E5E0D8;color:#555;transition:all .15s}.bucket-btn.active{border-color:#FF3B00;color:#FF3B00;background:#fff5f3}.upload-zone{background:#fff;border:2px dashed #E5E0D8;border-radius:16px;padding:2rem;text-align:center;margin-bottom:2rem;transition:border-color .2s}.upload-zone:hover{border-color:#FF3B00}.upload-label{font-size:.875rem;color:#888;cursor:pointer}.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:1rem}.media-card{background:#fff;border:1px solid #E5E0D8;border-radius:12px;overflow:hidden;transition:shadow .2s}.media-card:hover{box-shadow:0 4px 16px rgba(0,0,0,.08)}.media-thumb{width:100%;height:120px;object-fit:cover;background:#F7F5F2;display:block}.media-thumb.placeholder{display:flex;align-items:center;justify-content:center;font-size:2rem;color:#ccc}.media-info{padding:.625rem .75rem}.media-name{font-size:.7rem;color:#1A1A1A;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.media-size{font-size:.65rem;color:#aaa;margin-top:.125rem}.media-actions{display:flex;gap:.375rem;margin-top:.5rem}.copy-btn{flex:1;padding:.3rem;background:#F7F5F2;border:1px solid #E5E0D8;border-radius:6px;font-size:.65rem;cursor:pointer;color:#555;transition:all .15s}.copy-btn:hover{border-color:#FF3B00;color:#FF3B00}.btn-upload{padding:.75rem 1.5rem;background:#FF3B00;color:#fff;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.875rem;border:none;border-radius:10px;cursor:pointer;margin-top:.75rem}.toast{padding:.75rem 1.25rem;border-radius:10px;margin-bottom:1rem;font-size:.875rem;font-weight:500}.toast.ok{background:#f0fdf4;border:1px solid #86efac;color:#166534}.toast.err{background:#fef2f2;border:1px solid #fca5a5;color:#991b1b}#uploadInput{display:none}#copyToast{position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);background:#1A1A1A;color:#fff;padding:.625rem 1.25rem;border-radius:10px;font-size:.8125rem;opacity:0;transition:opacity .3s;pointer-events:none}</style>
</head><body>
<aside><div class="logo">Mash<span>Bano</span></div><nav><a href="/admin">Dashboard</a><a href="/admin/header">Header</a><a href="/admin/hero">Hero</a><a href="/admin/story">Story</a><a href="/admin/services">Services</a><a href="/admin/packages">Packages</a><a href="/admin/portfolio">Portfolio</a><a href="/admin/testimonials">Testimonials</a><a href="/admin/orders">Orders</a><a href="/admin/leads">Leads</a><a href="/admin/blog">Blog</a><a href="/admin/seo">SEO</a><a href="/admin/media" class="active">Media</a><a href="/admin/settings">Settings</a></nav><div class="sf"><a href="/">← View site</a></div></aside>
<main>
  <h1>Media Library</h1><p class="sub">Upload images to Supabase Storage — copy URL to use in any section</p>
  {error&&<div class="toast err">⚠ {error} (Make sure storage buckets are created in Supabase)</div>}
  <div class="buckets">
    {BUCKETS.map(b=>(<a href={`/admin/media?bucket=${b}`} class={`bucket-btn ${bucket===b?'active':''}`}>{b}</a>))}
  </div>
  <div class="upload-zone" id="dropZone">
    <div style="font-size:2rem;margin-bottom:.5rem">📁</div>
    <label class="upload-label" for="uploadInput">Click to upload or drag & drop images here<br/><span style="font-size:.75rem">PNG, JPG, WEBP, SVG · Max 5MB each</span></label>
    <input type="file" id="uploadInput" multiple accept="image/*"/>
    <div id="uploadProgress" style="display:none;margin-top:1rem;font-size:.8125rem;color:#FF3B00"></div>
  </div>
  <div class="grid" id="mediaGrid">
    {files.map(f=>{
      const url=`${PUBLIC_URL}${bucket}/${f.name}`;
      const isImg=/\.(jpg|jpeg|png|gif|webp|svg)$/i.test(f.name);
      return(
        <div class="media-card">
          {isImg?<img src={url} alt={f.name} class="media-thumb" loading="lazy"/>:<div class="media-thumb placeholder">📄</div>}
          <div class="media-info">
            <div class="media-name" title={f.name}>{f.name}</div>
            <div class="media-size">{f.metadata?.size?Math.round(f.metadata.size/1024)+'KB':''}</div>
            <div class="media-actions">
              <button class="copy-btn" data-url={url} onclick="copyUrl(this)">Copy URL</button>
            </div>
          </div>
        </div>
      );
    })}
    {files.length===0&&!error&&<div style="grid-column:1/-1;text-align:center;padding:3rem;color:#888">No files in this bucket yet. Upload some above!</div>}
  </div>
</main>
<div id="copyToast">URL copied!</div>
<script define:vars={{ bucket, supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL, supabaseAnon: import.meta.env.PUBLIC_SUPABASE_ANON_KEY }}>
  function copyUrl(btn) {
    navigator.clipboard.writeText(btn.dataset.url).then(()=>{
      const t=document.getElementById('copyToast');
      t.style.opacity='1';setTimeout(()=>t.style.opacity='0',2000);
    });
  }
  const input=document.getElementById('uploadInput');
  const prog=document.getElementById('uploadProgress');
  const grid=document.getElementById('mediaGrid');
  input?.addEventListener('change',async(e)=>{
    const files=e.target.files;
    if(!files?.length)return;
    prog.style.display='block';
    for(const file of files){
      prog.textContent=`Uploading ${file.name}...`;
      const res=await fetch(`${supabaseUrl}/storage/v1/object/${bucket}/${file.name}`,{
        method:'POST',
        headers:{'Authorization':`Bearer ${supabaseAnon}`,'Content-Type':file.type},
        body:file
      });
      if(res.ok){
        prog.textContent=`✓ ${file.name} uploaded!`;
        setTimeout(()=>location.reload(),1000);
      } else {
        prog.textContent=`✗ Failed: ${file.name}`;
      }
    }
  });
</script>
</body></html>
