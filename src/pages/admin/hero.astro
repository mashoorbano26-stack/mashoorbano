---
// src/pages/admin/hero.astro
// Full granular control: each of the 4 elements (MASHOOR, BANO, Circle, Marquee)
// has size, X/Y position, and colour controls.
export const prerender = false;
import { makeServerClient, supabaseAdmin } from '@/lib/supabase';

const supabase = makeServerClient(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/admin/login');

let saved = false;
let error = '';

if (Astro.request.method === 'POST') {
  const f = await Astro.request.formData();
  const get = (k: string, d = '') => f.get(k)?.toString() ?? d;
  const content: Record<string, string> = {
    // Word 1
    word1:               get('word1', 'MASHOOR'),
    word1_color:         get('word1_color', '#F5F5F0'),
    word1_size:          get('word1_size', 'clamp(2.2rem,7vw,5.5rem)'),
    word1_offset_x:      get('word1_offset_x', '0'),
    word1_offset_y:      get('word1_offset_y', '0'),
    // Word 2
    word2:               get('word2', 'BANO'),
    word2_color:         get('word2_color', '#FF3B00'),
    word2_size:          get('word2_size', 'clamp(2.2rem,7vw,5.5rem)'),
    word2_offset_x:      get('word2_offset_x', '0'),
    word2_offset_y:      get('word2_offset_y', '0'),
    // Circle / video
    video_url:           get('video_url'),
    circle_size:         get('circle_size', 'clamp(150px,17vw,260px)'),
    circle_border_color: get('circle_border_color', '#FFFFFF'),
    circle_border_width: get('circle_border_width', '2'),
    circle_offset_x:     get('circle_offset_x', '0'),
    circle_offset_y:     get('circle_offset_y', '0'),
    // Marquee
    orbital_text:        get('orbital_text', 'SEE MORE · SEE MORE · SEE MORE ·'),
    orbital_color:       get('orbital_color', '#FFFFFF'),
    orbital_size:        get('orbital_size', '11'),
    orbital_speed:       get('orbital_speed', '14'),
    marquee_hover_scale: get('marquee_hover_scale', '1.35'),
    // General
    words_gap:           get('words_gap', 'clamp(5rem,11vw,11rem)'),
    subheadline:         get('subheadline'),
    sub_offset_x:        get('sub_offset_x', '0'),
    sub_offset_y:        get('sub_offset_y', '0'),
    cta_primary_label:   get('cta_primary_label', 'See Packages'),
    cta_secondary_label: get('cta_secondary_label', 'Book a Free Call'),
    text_color:          get('text_color', '#F5F5F0'),
    accent_color:        get('accent_color', '#FF3B00'),
    bg_color:            get('bg_color', '#0A0A0A'),
    meta_line1:          get('meta_line1', 'Digital Agency'),
    meta_line2:          get('meta_line2', "India's Bold Brands"),
    meta_line3:          get('meta_line3', 'Est. 2024'),
    auto_expand_seconds: get('auto_expand_seconds', '0'),
  };
  const { error: e } = await supabaseAdmin
    .from('site_content')
    .upsert({ page: 'home', section: 'hero', content, updated_at: new Date().toISOString() }, { onConflict: 'page,section' });
  if (e) error = e.message;
  else saved = true;
}

const { data } = await supabaseAdmin.from('site_content').select('content').eq('page','home').eq('section','hero').single();
const c = (data?.content as Record<string,string>) ?? {};
const v = (k: string, d: string) => c[k] ?? d;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Hero Editor — Mashurban Admin</title>
  <meta name="robots" content="noindex,nofollow"/>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{background:#F7F5F2;color:#1A1A1A;font-family:Inter,sans-serif;min-height:100vh;display:flex}
    aside{width:220px;min-height:100vh;background:#fff;border-right:1px solid #E5E0D8;display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto;flex-shrink:0}
    .logo{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1rem;padding:1.25rem 1rem;border-bottom:1px solid #E5E0D8}
    .logo span{color:#FF3B00}
    nav a{display:block;padding:.45rem 1rem;color:#888;font-size:.8125rem;text-decoration:none;transition:all .15s;border-left:2px solid transparent}
    nav a:hover{color:#1A1A1A;background:#F7F5F2}
    nav a.active{color:#FF3B00;border-left-color:#FF3B00;background:#fff5f3}
    .sf{padding:.75rem 1rem;border-top:1px solid #E5E0D8;margin-top:auto}
    .sf a{font-size:.75rem;color:#888;text-decoration:none}
    main{flex:1;padding:2rem;max-width:920px}
    h1{font-family:'Space Grotesk',sans-serif;font-size:1.375rem;font-weight:700;margin-bottom:.25rem;letter-spacing:-.02em}
    .sub{color:#888;font-size:.8125rem;margin-bottom:1.5rem}
    .card{background:#fff;border:1px solid #E5E0D8;border-radius:16px;padding:1.75rem;margin-bottom:1.25rem}
    .card-title{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.9375rem;margin-bottom:1.25rem;display:flex;align-items:center;gap:.5rem}
    .card-title::before{content:'';width:3px;height:1rem;background:#FF3B00;border-radius:2px;flex-shrink:0}
    .badge{font-size:.6rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.15rem .5rem;border-radius:999px;background:#fff5f3;color:#FF3B00;margin-left:.5rem}
    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem}
    .grid4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:.75rem}
    .field{display:flex;flex-direction:column;gap:.375rem;margin-bottom:.75rem}
    label{font-size:.7rem;font-weight:600;color:#666;text-transform:uppercase;letter-spacing:.06em}
    input[type=text],input[type=url],input[type=number],input[type=color],textarea{width:100%;background:#F7F5F2;border:1.5px solid #E5E0D8;border-radius:10px;padding:.625rem .875rem;color:#1A1A1A;font-size:.875rem;font-family:inherit;outline:none;transition:border-color .2s}
    input[type=color]{height:44px;padding:.3rem .5rem;cursor:pointer}
    input:focus,textarea:focus{border-color:#FF3B00}
    .range-row{display:flex;align-items:center;gap:.6rem}
    input[type=range]{flex:1;accent-color:#FF3B00}
    .range-val{font-size:.8rem;font-weight:700;color:#FF3B00;min-width:3.2rem;text-align:right}
    .hint{font-size:.7rem;color:#aaa;margin-top:.2rem;line-height:1.5}
    .hint code{background:#F0EDE8;padding:.1rem .35rem;border-radius:4px;font-size:.7rem}
    .btn-save{padding:.875rem 2.5rem;background:#FF3B00;color:#fff;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.9375rem;border:none;border-radius:12px;cursor:pointer;transition:background .2s}
    .btn-save:hover{background:#e03200}
    .toast{padding:.875rem 1.25rem;border-radius:12px;margin-bottom:1.5rem;font-size:.875rem;font-weight:500;display:flex;align-items:center;gap:.5rem}
    .toast.ok{background:#f0fdf4;border:1px solid #86efac;color:#166534}
    .toast.err{background:#fef2f2;border:1px solid #fca5a5;color:#991b1b}
    .pos-note{background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;padding:.6rem .85rem;font-size:.72rem;color:#1e40af;margin-bottom:.75rem;line-height:1.5}
  </style>
</head>
<body>
<aside>
  <div class="logo">Mash<span>urban</span></div>
  <nav>
    <a href="/admin">Dashboard</a>
    <a href="/admin/header">Header</a>
    <a href="/admin/hero" class="active">Hero</a>
    <a href="/admin/story">Story</a>
    <a href="/admin/services">Services</a>
    <a href="/admin/packages">Packages</a>
    <a href="/admin/portfolio">Portfolio</a>
    <a href="/admin/testimonials">Testimonials</a>
    <a href="/admin/orders">Orders</a>
    <a href="/admin/leads">Leads</a>
    <a href="/admin/blog">Blog</a>
    <a href="/admin/seo">SEO</a>
    <a href="/admin/media">Media</a>
    <a href="/admin/settings">Settings</a>
  </nav>
  <div class="sf"><a href="/" target="_blank">← View site</a></div>
</aside>

<main>
  <h1>Hero Section</h1>
  <p class="sub">Full control over MASHOOR, BANO, the video circle, and the marquee — size, position, and colour for each</p>

  {saved && <div class="toast ok">✓ Saved! Refresh the homepage to see changes.</div>}
  {error && <div class="toast err">⚠ {error}</div>}

  <form method="POST">

    <!-- ══ WORD 1: MASHOOR ══ -->
    <div class="card">
      <div class="card-title">Word 1 <span class="badge">MASHOOR (left)</span></div>
      <div class="grid2">
        <div class="field"><label>Text</label><input type="text" name="word1" value={v('word1','MASHOOR')}/></div>
        <div class="field"><label>Colour</label><input type="color" name="word1_color" value={v('word1_color','#F5F5F0')}/></div>
      </div>
      <div class="field">
        <label>Font Size (CSS)</label>
        <input type="text" name="word1_size" value={v('word1_size','clamp(2.2rem,7vw,5.5rem)')}/>
        <span class="hint">Use <code>clamp(min,preferred,max)</code> for responsive, or a fixed value like <code>4rem</code></span>
      </div>
      <div class="pos-note">📍 Position: drag to nudge the word. X moves left↔right, Y moves up↕down. 0 = default centred position.</div>
      <div class="grid2">
        <div class="field"><label>Horizontal Position (X)</label>
          <div class="range-row"><input type="range" name="word1_offset_x" min="-200" max="200" step="1" value={v('word1_offset_x','0')} id="w1x"/><span class="range-val" id="w1xv">{v('word1_offset_x','0')}px</span></div>
        </div>
        <div class="field"><label>Vertical Position (Y)</label>
          <div class="range-row"><input type="range" name="word1_offset_y" min="-200" max="200" step="1" value={v('word1_offset_y','0')} id="w1y"/><span class="range-val" id="w1yv">{v('word1_offset_y','0')}px</span></div>
        </div>
      </div>
    </div>

    <!-- ══ WORD 2: BANO ══ -->
    <div class="card">
      <div class="card-title">Word 2 <span class="badge">BANO (right)</span></div>
      <div class="grid2">
        <div class="field"><label>Text</label><input type="text" name="word2" value={v('word2','BANO')}/></div>
        <div class="field"><label>Colour</label><input type="color" name="word2_color" value={v('word2_color','#FF3B00')}/></div>
      </div>
      <div class="field">
        <label>Font Size (CSS)</label>
        <input type="text" name="word2_size" value={v('word2_size','clamp(2.2rem,7vw,5.5rem)')}/>
        <span class="hint">Tip: make this match Word 1's size for symmetry, or differ for emphasis</span>
      </div>
      <div class="pos-note">📍 Position: 0 = default. Negative X = left, positive X = right. Negative Y = up, positive Y = down.</div>
      <div class="grid2">
        <div class="field"><label>Horizontal Position (X)</label>
          <div class="range-row"><input type="range" name="word2_offset_x" min="-200" max="200" step="1" value={v('word2_offset_x','0')} id="w2x"/><span class="range-val" id="w2xv">{v('word2_offset_x','0')}px</span></div>
        </div>
        <div class="field"><label>Vertical Position (Y)</label>
          <div class="range-row"><input type="range" name="word2_offset_y" min="-200" max="200" step="1" value={v('word2_offset_y','0')} id="w2y"/><span class="range-val" id="w2yv">{v('word2_offset_y','0')}px</span></div>
        </div>
      </div>
    </div>

    <!-- ══ CIRCLE / VIDEO ══ -->
    <div class="card">
      <div class="card-title">Video Circle <span class="badge">centre</span></div>
      <div class="field">
        <label>Video URL</label>
        <input type="text" name="video_url" value={v('video_url','https://www.w3schools.com/html/mov_bbb.mp4')} placeholder="YouTube, Instagram, or .mp4 link"/>
        <span class="hint">Paste ANY of these:<br/>• <b>YouTube:</b> <code>youtube.com/watch?v=...</code> or <code>youtu.be/...</code><br/>• <b>Instagram:</b> <code>instagram.com/reel/...</code><br/>• <b>Direct video:</b> <code>/videos/file.mp4</code> or any <code>.mp4</code> URL</span>
      </div>
      <div class="grid2">
        <div class="field">
          <label>Circle Size (CSS)</label>
          <input type="text" name="circle_size" value={v('circle_size','clamp(150px,17vw,260px)')}/>
          <span class="hint">e.g. <code>260px</code> fixed, or <code>clamp(150px,17vw,260px)</code> responsive</span>
        </div>
        <div class="field">
          <label>Border / Strip Colour</label>
          <input type="color" name="circle_border_color" value={v('circle_border_color','#FFFFFF')}/>
          <span class="hint">The ring around the video (white = Amsterdam style)</span>
        </div>
      </div>
      <div class="field">
        <label>Border Width (px)</label>
        <div class="range-row"><input type="range" name="circle_border_width" min="0" max="12" step="1" value={v('circle_border_width','2')} id="cbw"/><span class="range-val" id="cbwv">{v('circle_border_width','2')}px</span></div>
      </div>
      <div class="pos-note">📍 Position the circle anywhere relative to the centre of the words.</div>
      <div class="grid2">
        <div class="field"><label>Horizontal Position (X)</label>
          <div class="range-row"><input type="range" name="circle_offset_x" min="-300" max="300" step="1" value={v('circle_offset_x','0')} id="cx"/><span class="range-val" id="cxv">{v('circle_offset_x','0')}px</span></div>
        </div>
        <div class="field"><label>Vertical Position (Y)</label>
          <div class="range-row"><input type="range" name="circle_offset_y" min="-200" max="200" step="1" value={v('circle_offset_y','0')} id="cy"/><span class="range-val" id="cyv">{v('circle_offset_y','0')}px</span></div>
        </div>
      </div>
    </div>

    <!-- ══ MARQUEE ══ -->
    <div class="card">
      <div class="card-title">Marquee Ring <span class="badge">around circle</span></div>
      <div class="field">
        <label>Marquee Text</label>
        <input type="text" name="orbital_text" value={v('orbital_text','SEE MORE · SEE MORE · SEE MORE ·')}/>
        <span class="hint">Curves around the circle. Use <code>·</code> separators. Faint by default, brightens on hover.</span>
      </div>
      <div class="grid3">
        <div class="field"><label>Colour</label><input type="color" name="orbital_color" value={v('orbital_color','#FFFFFF')}/></div>
        <div class="field">
          <label>Font Size</label>
          <div class="range-row"><input type="range" name="orbital_size" min="6" max="20" step="0.5" value={v('orbital_size','11')} id="osz"/><span class="range-val" id="oszv">{v('orbital_size','11')}px</span></div>
        </div>
        <div class="field">
          <label>Spin Speed (s)</label>
          <div class="range-row"><input type="range" name="orbital_speed" min="4" max="40" step="1" value={v('orbital_speed','14')} id="osp"/><span class="range-val" id="ospv">{v('orbital_speed','14')}s</span></div>
        </div>
      </div>
      <div class="field">
        <label>Marquee Size on Hover (how much bigger the moving ring grows)</label>
        <div class="range-row"><input type="range" name="marquee_hover_scale" min="1" max="2.5" step="0.05" value={v('marquee_hover_scale','1.35')} id="mhs"/><span class="range-val" id="mhsv">{v('marquee_hover_scale','1.35')}×</span></div>
        <span class="hint">On hover the orange arrow appears in the centre and the moving marquee ring grows to this size around it. 1× = no growth, 2× = double size.</span>
      </div>
    </div>

    <!-- ══ GENERAL ══ -->
    <div class="card">
      <div class="card-title">Layout & General</div>
      <div class="field">
        <label>Gap Between Words (controls how much circle overlaps)</label>
        <input type="text" name="words_gap" value={v('words_gap','clamp(5rem,11vw,11rem)')}/>
        <span class="hint">Bigger gap = circle sits in open space. Smaller gap = circle overlaps letters more (Amsterdam look).</span>
      </div>
      <div class="field"><label>Subheadline</label><input type="text" name="subheadline" value={v('subheadline','Websites · Merch · Content · Meta Ads · Google Ads')}/></div>
      <div class="pos-note">📍 Move the subheadline line up/down/left/right just like the words. 0 = default centred.</div>
      <div class="grid2">
        <div class="field"><label>Subheadline Position (X)</label>
          <div class="range-row"><input type="range" name="sub_offset_x" min="-300" max="300" step="1" value={v('sub_offset_x','0')} id="sx"/><span class="range-val" id="sxv">{v('sub_offset_x','0')}px</span></div>
        </div>
        <div class="field"><label>Subheadline Position (Y)</label>
          <div class="range-row"><input type="range" name="sub_offset_y" min="-300" max="300" step="1" value={v('sub_offset_y','0')} id="sy"/><span class="range-val" id="syv">{v('sub_offset_y','0')}px</span></div>
        </div>
      </div>
      <div class="grid2">
        <div class="field"><label>Primary CTA</label><input type="text" name="cta_primary_label" value={v('cta_primary_label','See Packages')}/></div>
        <div class="field"><label>Secondary CTA</label><input type="text" name="cta_secondary_label" value={v('cta_secondary_label','Book a Free Call')}/></div>
      </div>
      <div class="grid4">
        <div class="field"><label>Background</label><input type="color" name="bg_color" value={v('bg_color','#0A0A0A')}/></div>
        <div class="field"><label>Body Text</label><input type="color" name="text_color" value={v('text_color','#F5F5F0')}/></div>
        <div class="field"><label>Accent (CTA)</label><input type="color" name="accent_color" value={v('accent_color','#FF3B00')}/></div>
        <div class="field">
          <label>Auto-Expand (s)</label>
          <div class="range-row"><input type="range" name="auto_expand_seconds" min="0" max="30" step="1" value={v('auto_expand_seconds','0')} id="aut"/><span class="range-val" id="autv">{v('auto_expand_seconds','0')==='0'?'Off':v('auto_expand_seconds','0')+'s'}</span></div>
        </div>
      </div>
      <div class="grid3">
        <div class="field"><label>Meta Line 1</label><input type="text" name="meta_line1" value={v('meta_line1','Digital Agency')}/></div>
        <div class="field"><label>Meta Line 2</label><input type="text" name="meta_line2" value={v('meta_line2',"India's Bold Brands")}/></div>
        <div class="field"><label>Meta Line 3</label><input type="text" name="meta_line3" value={v('meta_line3','Est. 2024')}/></div>
      </div>
    </div>

    <button type="submit" class="btn-save">Save Hero →</button>
  </form>
</main>

<script>
  const link = (rangeId: string, valId: string, suffix = 'px') => {
    const r = document.getElementById(rangeId) as HTMLInputElement;
    const o = document.getElementById(valId);
    r?.addEventListener('input', () => {
      if (!o) return;
      if (suffix === 's' && r.value === '0') { o.textContent = 'Off'; return; }
      o.textContent = r.value + suffix;
    });
  };
  link('w1x','w1xv'); link('w1y','w1yv');
  link('w2x','w2xv'); link('w2y','w2yv');
  link('cx','cxv');   link('cy','cyv');
  link('cbw','cbwv');
  link('osz','oszv'); link('osp','ospv','s');
  (function(){const r=document.getElementById('mhs');const o=document.getElementById('mhsv');r&&r.addEventListener('input',()=>{if(o)o.textContent=r.value+'×';});})();
  link('sx','sxv'); link('sy','syv');
  link('aut','autv','s');
</script>
</body>
</html>
