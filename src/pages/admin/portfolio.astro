---
export const prerender = false;
import { makeServerClient, supabaseAdmin } from '@/lib/supabase';
const supabase = makeServerClient(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/admin/login');

let saved = false; let error = '';
if (Astro.request.method === 'POST') {
  const f = await Astro.request.formData();
  const act = f.get('_action')?.toString();
  if (act === 'save') {
    const id = f.get('id')?.toString();
    const row = { title: f.get('title')?.toString()??'', client_name: f.get('client_name')?.toString()??'', service_type: f.get('service_type')?.toString()??'website', description: f.get('description')?.toString()??'', result_metric: f.get('result_metric')?.toString()??'', thumbnail_url: f.get('thumbnail_url')?.toString()||null, tags: (f.get('tags')?.toString()??'').split(',').map((t:string)=>t.trim()).filter(Boolean), is_featured: f.get('is_featured')==='on', is_active: f.get('is_active')!=='off', sort_order: parseInt(f.get('sort_order')?.toString()??'0') };
    if (id) { const{error:e}=await supabaseAdmin.from('portfolio').update(row).eq('id',id); if(e)error=e.message;else saved=true; }
    else    { const{error:e}=await supabaseAdmin.from('portfolio').insert(row);              if(e)error=e.message;else saved=true; }
  }
}
const { data: items } = await supabaseAdmin.from('portfolio').select('*').order('sort_order');
const rows = items ?? [];
---
<!DOCTYPE html><html lang="en"><head>
  <meta charset="UTF-8"/><title>Portfolio — Mashurban Admin</title><meta name="robots" content="noindex,nofollow"/>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet"/>
  <style>*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}body{background:#F7F5F2;color:#1A1A1A;font-family:Inter,sans-serif;min-height:100vh;display:flex}aside{width:220px;min-height:100vh;background:#fff;border-right:1px solid #E5E0D8;display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto;flex-shrink:0}.logo{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1rem;padding:1.25rem 1rem;border-bottom:1px solid #E5E0D8}.logo span{color:#FF3B00}nav a{display:block;padding:.45rem 1rem;color:#888;font-size:.8125rem;text-decoration:none;border-left:2px solid transparent;transition:all .15s}nav a:hover{color:#1A1A1A;background:#F7F5F2}nav a.active{color:#FF3B00;border-left-color:#FF3B00;background:#fff5f3}.sf{padding:.75rem 1rem;border-top:1px solid #E5E0D8;margin-top:auto}.sf a{font-size:.75rem;color:#888;text-decoration:none}main{flex:1;padding:2rem;max-width:900px}h1{font-family:'Space Grotesk',sans-serif;font-size:1.375rem;font-weight:700;margin-bottom:.25rem}.sub{color:#888;font-size:.8125rem;margin-bottom:2rem}.card{background:#fff;border:1px solid #E5E0D8;border-radius:16px;padding:1.5rem;margin-bottom:1rem}.new-form{background:#fff5f3;border:1.5px dashed #FF3B00;border-radius:16px;padding:1.5rem;margin-bottom:1.5rem}.new-title{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.9375rem;color:#FF3B00;margin-bottom:1rem}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:.75rem}.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:.75rem}.field{display:flex;flex-direction:column;gap:.3rem;margin-bottom:.5rem}label{font-size:.7rem;font-weight:500;color:#666;text-transform:uppercase;letter-spacing:.06em}input[type=text],input[type=url],input[type=number],select,textarea{width:100%;background:#F7F5F2;border:1.5px solid #E5E0D8;border-radius:8px;padding:.5rem .75rem;color:#1A1A1A;font-size:.8125rem;font-family:inherit;outline:none;transition:border-color .2s}input:focus,select:focus,textarea:focus{border-color:#FF3B00}textarea{resize:vertical;min-height:70px}.checks{display:flex;gap:1rem;margin:.5rem 0}.check-label{display:flex;align-items:center;gap:.375rem;font-size:.8125rem;color:#555;cursor:pointer}input[type=checkbox]{accent-color:#FF3B00}.btn-save{padding:.55rem 1.25rem;background:#FF3B00;color:#fff;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.8125rem;border:none;border-radius:8px;cursor:pointer;margin-top:.75rem}.toast{padding:.75rem 1.25rem;border-radius:10px;margin-bottom:1rem;font-size:.875rem;font-weight:500}.toast.ok{background:#f0fdf4;border:1px solid #86efac;color:#166534}.toast.err{background:#fef2f2;border:1px solid #fca5a5;color:#991b1b}details summary{cursor:pointer;list-style:none}.hint{font-size:.7rem;color:#aaa;margin-top:.2rem}</style>
</head><body>
<aside><div class="logo">Mash<span>urban</span></div><nav><a href="/admin">Dashboard</a><a href="/admin/header">Header</a><a href="/admin/hero">Hero</a><a href="/admin/story">Story</a><a href="/admin/services">Services</a><a href="/admin/packages">Packages</a><a href="/admin/portfolio" class="active">Portfolio</a><a href="/admin/testimonials">Testimonials</a><a href="/admin/orders">Orders</a><a href="/admin/leads">Leads</a><a href="/admin/blog">Blog</a><a href="/admin/seo">SEO</a><a href="/admin/media">Media</a><a href="/admin/settings">Settings</a></nav><div class="sf"><a href="/">← View site</a></div></aside>
<main>
  <h1>Portfolio</h1><p class="sub">Add and manage case studies and work samples</p>
  {saved && <div class="toast ok">✓ Saved!</div>}
  {error && <div class="toast err">⚠ {error}</div>}
  <div class="new-form">
    <div class="new-title">+ Add Portfolio Item</div>
    <form method="POST"><input type="hidden" name="_action" value="save"/>
      <div class="grid2">
        <div class="field"><label>Project Title</label><input type="text" name="title" placeholder="UrbanFit Website Redesign" required/></div>
        <div class="field"><label>Client Name</label><input type="text" name="client_name" placeholder="UrbanFit Apparel"/></div>
        <div class="field"><label>Service Type</label><select name="service_type"><option value="website">Website</option><option value="merchandise">Merchandise</option><option value="content">Content</option><option value="meta-ads">Meta Ads</option><option value="google-ads">Google Ads</option><option value="branding">Branding</option></select></div>
        <div class="field"><label>Result Metric</label><input type="text" name="result_metric" placeholder="3× ROAS in 30 days"/></div>
        <div class="field"><label>Thumbnail URL</label><input type="url" name="thumbnail_url" placeholder="https://..."/></div>
        <div class="field"><label>Tags (comma-separated)</label><input type="text" name="tags" placeholder="website, ecommerce, fashion"/></div>
        <div class="field"><label>Sort Order</label><input type="number" name="sort_order" value="0"/></div>
      </div>
      <div class="field"><label>Description</label><textarea name="description" rows="3" placeholder="What was done and why it worked..."></textarea></div>
      <div class="checks"><label class="check-label"><input type="checkbox" name="is_featured"/> Featured</label><label class="check-label"><input type="checkbox" name="is_active" checked/> Active</label></div>
      <button type="submit" class="btn-save">Add Item</button>
    </form>
  </div>
  {rows.map((item: any) => (
    <div class="card">
      <details>
        <summary style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.9375rem;padding:.25rem 0">{item.title} <span style="font-weight:400;color:#888;font-size:.8125rem">· {item.client_name}</span></summary>
        <form method="POST" style="margin-top:1rem"><input type="hidden" name="_action" value="save"/><input type="hidden" name="id" value={item.id}/>
          <div class="grid2">
            <div class="field"><label>Title</label><input type="text" name="title" value={item.title}/></div>
            <div class="field"><label>Client</label><input type="text" name="client_name" value={item.client_name??''}/></div>
            <div class="field"><label>Service Type</label><select name="service_type"><option value="website" selected={item.service_type==='website'}>Website</option><option value="merchandise" selected={item.service_type==='merchandise'}>Merchandise</option><option value="content" selected={item.service_type==='content'}>Content</option><option value="meta-ads" selected={item.service_type==='meta-ads'}>Meta Ads</option><option value="google-ads" selected={item.service_type==='google-ads'}>Google Ads</option><option value="branding" selected={item.service_type==='branding'}>Branding</option></select></div>
            <div class="field"><label>Result Metric</label><input type="text" name="result_metric" value={item.result_metric??''}/></div>
            <div class="field"><label>Thumbnail URL</label><input type="url" name="thumbnail_url" value={item.thumbnail_url??''}/></div>
            <div class="field"><label>Tags</label><input type="text" name="tags" value={Array.isArray(item.tags)?item.tags.join(', '):''}/></div>
            <div class="field"><label>Sort Order</label><input type="number" name="sort_order" value={item.sort_order??0}/></div>
          </div>
          <div class="field"><label>Description</label><textarea name="description" rows="3">{item.description??''}</textarea></div>
          <div class="checks"><label class="check-label"><input type="checkbox" name="is_featured" checked={item.is_featured}/> Featured</label><label class="check-label"><input type="checkbox" name="is_active" checked={item.is_active}/> Active</label></div>
          <button type="submit" class="btn-save">Save</button>
        </form>
      </details>
    </div>
  ))}
</main></body></html>
