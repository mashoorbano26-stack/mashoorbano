---
export const prerender = false;
import AdminLayout from '@/components/admin/AdminLayout';
import ThemeManager from '@/components/admin/ThemeManager';
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Theme & Colors | MashoorBano Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <meta name="robots" content="noindex,nofollow" />
  </head>
  <body class="bg-[#0A0A0A] text-white font-body">
    <div id="admin-theme-root">
      <AdminLayout client:load page="theme">
        <ThemeManager client:load />
      </AdminLayout>
    </div>
  </body>
</html>
