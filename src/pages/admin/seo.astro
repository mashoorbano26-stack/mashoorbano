---
export const prerender = false;
import { makeServerClient, getAdmin } from '@/lib/supabase';
const supabase = makeServerClient(Astro.cookies);
const supabaseAdmin = getAdmin(Astro.locals);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/admin/login');
let saved=false,error='';
if(Astro.request.method==='POST'){
  const f=await Astro.request.formData();
  const row={page_path:f.get('page_path')?.toString()??'/',title:f.get('title')?.toString()??'',description:f.get('description')?.toString()??'',og_title:f.get('og_title')?.toString()??'',og_description:f.get('og_description')?.toString()??'',og_image_url:f.get('og_image_url')?.toString()||null,canonical_url:f.get('canonical_url')?.toString()||null,keywords:f.get('keywords')?.toString()??'',updated_at:new Date().toISOString()};
  const{error:e}=await supabaseAdmin.from('seo_settings').upsert(row,{onConflict:'page_path'});
  if(e)error=e.message;else saved=true;
}
const PAGES=[{path:'/',label:'Homepage'},{path:'/services',label:'Services'},{path:'/services/websites',label:'Website Design'},{path:'/services/merchandise',label:'Merchandise'},{path:'/services/content-creation',label:'Content Creation'},{path:'/services/meta-ads',label:'Meta Ads'},{path:'/services/google-ads',label:'Google Ads'},{path:'/packages',label:'Packages'},{path:'/portfolio',label:'Portfolio'},{path:'/about',label:'About'},{path:'/contact',label:'Contact'},{path:'/blog',label:'Blog'}];
const selectedPath=Astro.url.searchParams.get('page')??'/';
const{data:seoData}=await supabaseAdmin.from('seo_settings').select('*').eq('page_path',selectedPath).single();
const s=seoData??{};
---
<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"/><title>SEO — MashoorBano Admin</title><meta name="robots" content="noindex,nofollow"/><link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet"/>
<style>*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}body{background:#F7F5F2;color:#1A1A1A;font-family:Inter,sans-serif;min-height:100vh;display:flex}aside{width:220px;min-height:100vh;background:#fff;border-right:1px solid #E5E0D8;display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto;flex-shrink:0}.logo{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1rem;padding:1.25rem 1rem;border-bottom:1px solid #E5E0D8}.logo span{color:#FF3B00}nav a{display:block;padding:.45rem 1rem;color:#888;font-size:.8125rem;text-decoration:none;border-left:2px solid transparent;transition:all .15s}nav a:hover{color:#1A1A1A;background:#F7F5F2}nav a.active{color:#FF3B00;border-left-color:#FF3B00;background:#fff5f3}.sf{padding:.75rem 1rem;border-top:1px solid #E5E0D8;margin-top:auto}.sf a{font-size:.75rem;color:#888;text-decoration:none}main{flex:1;padding:2rem;max-width:900px}h1{font-family:'Space Grotesk',sans-serif;font-size:1.375rem;font-weight:700;margin-bottom:.25rem}.sub{color:#888;font-size:.8125rem;margin-bottom:1.5rem}.page-tabs{display:flex;flex-wrap:wrap;gap:.375rem;margin-bottom:2rem}.page-tab{padding:.375rem .875rem;border-radius:999px;font-size:.75rem;font-weight:600;text-decoration:none;border:1.5px solid #E5E0D8;color:#555;transition:all .15s}.page-tab:hover,.page-tab.active{border-color:#FF3B00;color:#FF3B00;background:#fff5f3}.card{background:#fff;border:1px solid #E5E0D8;border-radius:16px;padding:1.75rem;margin-bottom:1.5rem}.card-title{font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:.9375rem;margin-bottom:1.25rem;display:flex;align-items:center;gap:.5rem}.card-title::before{content:'';width:3px;height:1rem;background:#FF3B00;border-radius:2px}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:.75rem}.field{display:flex;flex-direction:column;gap:.3rem;margin-bottom:.5rem}label{font-size:.7rem;font-weight:500;color:#666;text-transform:uppercase;letter-spacing:.06em}input[type=text],input[type=url],textarea{width:100%;background:#F7F5F2;border:1.5px solid #E5E0D8;border-radius:8px;padding:.5rem .75rem;color:#1A1A1A;font-size:.8125rem;font-family:inherit;outline:none;transition:border-color .2s}input:focus,textarea:focus{border-color:#FF3B00}textarea{resize:vertical}.btn-save{padding:.75rem 2rem;background:#FF3B00;color:#fff;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.875rem;border:none;border-radius:10px;cursor:pointer}.toast{padding:.75rem 1.25rem;border-radius:10px;margin-bottom:1rem;font-size:.875rem;font-weight:500}.toast.ok{background:#f0fdf4;border:1px solid #86efac;color:#166534}.toast.err{background:#fef2f2;border:1px solid #fca5a5;color:#991b1b}.hint{font-size:.7rem;color:#aaa;margin-top:.2rem}.char-count{font-size:.7rem;color:#aaa;text-align:right}</style>
</head><body>
<aside><div class="logo">Mashoor<span>Bano</span></div><nav><a href="/admin">Dashboard</a><a href="/admin/header">Header</a><a href="/admin/hero">Hero</a><a href="/admin/story">Story</a><a href="/admin/services">Services</a><a href="/admin/packages">Packages</a><a href="/admin/portfolio">Portfolio</a><a href="/admin/testimonials">Testimonials</a><a href="/admin/orders">Orders</a><a href="/admin/leads">Leads</a><a href="/admin/blog">Blog</a><a href="/admin/seo" class="active">SEO</a><a href="/admin/media">Media</a><a href="/admin/settings">Settings</a></nav><div class="sf"><a href="/">← View site</a></div></aside>
<main><h1>SEO Settings</h1><p class="sub">Set meta title, description, and OG image per page</p>
{saved&&<div class="toast ok">✓ SEO saved for {selectedPath}!</div>}{error&&<div class="toast err">⚠ {error}</div>}
<div class="page-tabs">
  {PAGES.map(p=>(<a href={`/admin/seo?page=${encodeURIComponent(p.path)}`} class={`page-tab ${selectedPath===p.path?'active':''}`}>{p.label}</a>))}
</div>
<form method="POST">
  <input type="hidden" name="page_path" value={selectedPath}/>
  <div class="card"><div class="card-title">Page: {PAGES.find(p=>p.path===selectedPath)?.label ?? selectedPath}</div>
    <div class="field"><label>SEO Title (shown in Google)</label><input type="text" name="title" value={(s as any).title??''} maxlength="60" id="seoTitle"/><span class="hint">Keep under 60 characters</span></div>
    <div class="field"><label>Meta Description</label><textarea name="description" rows="2" maxlength="160" id="seoDesc">{(s as any).description??''}</textarea><span class="hint">Keep under 160 characters</span></div>
    <div class="field"><label>Keywords</label><input type="text" name="keywords" value={(s as any).keywords??''} placeholder="digital agency india, website design, MashoorBano"/></div>
  </div>
  <div class="card"><div class="card-title">Open Graph (Social Sharing)</div>
    <div class="field"><label>OG Title</label><input type="text" name="og_title" value={(s as any).og_title??''} placeholder="Leave blank to use SEO title"/></div>
    <div class="field"><label>OG Description</label><textarea name="og_description" rows="2">{(s as any).og_description??''}</textarea></div>
    <div class="field"><label>OG Image URL</label><input type="url" name="og_image_url" value={(s as any).og_image_url??''} placeholder="https://... (1200×630px recommended)"/></div>
    <div class="field"><label>Canonical URL (optional)</label><input type="url" name="canonical_url" value={(s as any).canonical_url??''} placeholder="Leave blank for default"/></div>
  </div>
  <button type="submit" class="btn-save">Save SEO for this page →</button>
</form>
</main></body></html>
