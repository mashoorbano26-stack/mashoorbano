---
// src/pages/admin/services.astro
export const prerender = false;
import { makeServerClient, supabaseAdmin } from '@/lib/supabase';
const supabase = makeServerClient(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/admin/login');

let saved = false; let error = '';
if (Astro.request.method === 'POST') {
  const f = await Astro.request.formData();
  const count = parseInt(f.get('service_count')?.toString() ?? '6');
  const services = Array.from({ length: count }, (_, i) => ({
    id: `service-${i+1}`,
    num: String(i+1).padStart(2,'0'),
    icon: f.get(`icon_${i}`)?.toString() ?? '',
    name: f.get(`name_${i}`)?.toString() ?? '',
    desc: f.get(`desc_${i}`)?.toString() ?? '',
    href: f.get(`href_${i}`)?.toString() ?? '',
    is_active: f.get(`active_${i}`) === 'on',
    sort_order: i,
  })).filter(s => s.name);
  const content = {
    section_label: f.get('section_label')?.toString() ?? '02 — What we do',
    section_heading: f.get('section_heading')?.toString() ?? 'What we do',
    bg_color: f.get('bg_color')?.toString() ?? '#F7F5F2',
    card_bg: f.get('card_bg')?.toString() ?? '#ffffff',
    text_color: f.get('text_color')?.toString() ?? '#1A1A1A',
    accent_color: f.get('accent_color')?.toString() ?? '#FF3B00',
    services,
  };
  const { error: e } = await supabaseAdmin.from('site_content').upsert({ page:'home', section:'services', content, updated_at: new Date().toISOString() }, { onConflict:'page,section' });
  if (e) error = e.message; else saved = true;
}
const { data } = await supabaseAdmin.from('site_content').select('content').eq('page','home').eq('section','services').single();
const c = (data?.content as any) ?? {};
const services = c.services ?? [
  { num:'01', icon:'⬡', name:'Website Design',  desc:'Fast, SEO-ready sites that convert visitors into clients.',   href:'/services/websites',        is_active:true },
  { num:'02', icon:'◈', name:'Merchandise',      desc:'T-shirts, caps, custom drops — merch your audience wants.',   href:'/services/merchandise',     is_active:true },
  { num:'03', icon:'▶', name:'Content Creation', desc:'Reels, shoots, scripting — content that stops the scroll.',   href:'/services/content-creation',is_active:true },
  { num:'04', icon:'◉', name:'Meta Ads',         desc:'Facebook + Instagram campaigns that spend less, return more.',href:'/services/meta-ads',        is_active:true },
  { num:'05', icon:'◎', name:'Google Ads',       desc:'Search, Display, YouTube — show up when customers look.',     href:'/services/google-ads',      is_active:true },
  { num:'06', icon:'◆', name:'Brand Identity',   desc:'Logo, palette, typeface, voice — a brand system to scale.',   href:'/services/branding',        is_active:true },
];
---
<!DOCTYPE html><html lang="en"><head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Services Editor — MashoorBano Admin</title><meta name="robots" content="noindex,nofollow"/>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{background:#F7F5F2;color:#1A1A1A;font-family:Inter,sans-serif;min-height:100vh;display:flex}
    aside{width:220px;min-height:100vh;background:#fff;border-right:1px solid #E5E0D8;display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto;flex-shrink:0}
    .logo{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1rem;padding:1.25rem 1rem;border-bottom:1px solid #E5E0D8}
    .logo span{color:#FF3B00}
    nav a{display:block;padding:.45rem 1rem;color:#888;font-size:.8125rem;text-decoration:none;border-left:2px solid transparent;transition:all .15s}
    nav a:hover{color:#1A1A1A;background:#F7F5F2}
    nav a.active{color:#FF3B00;border-left-color:#FF3B00;background:#fff5f3}
    .sf{padding:.75rem 1rem;border-top:1px solid #E5E0D8;margin-top:auto}
    .sf a{font-size:.75rem;color:#888;text-decoration:none}
    main{flex:1;padding:2rem;max-width:960px}
    h1{font-family:'Space Grotesk',sans-serif;font-size:1.375rem;font-weight:700;margin-bottom:.25rem;letter-spacing:-.02em}
    .sub{color:#888;font-size:.8125rem;margin-bottom:2rem}
    .card{background:#fff;border:1px solid #E5E0D8;border-radius:16px;padding:1.5rem;margin-bottom:1rem}
    .card-title{font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:.9375rem;margin-bottom:1rem;display:flex;align-items:center;gap:.5rem}
    .card-title::before{content:'';width:3px;height:1rem;background:#FF3B00;border-radius:2px}
    .svc-card{background:#F7F5F2;border:1px solid #E5E0D8;border-radius:12px;padding:1.25rem;margin-bottom:.75rem}
    .svc-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem}
    .svc-num{font-family:'Space Grotesk',sans-serif;font-weight:700;color:#FF3B00;font-size:.875rem}
    .toggle{display:flex;align-items:center;gap:.375rem;font-size:.75rem;color:#666}
    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:.75rem}
    .grid3{display:grid;grid-template-columns:80px 1fr 1fr;gap:.75rem}
    .grid4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:.75rem}
    .field{display:flex;flex-direction:column;gap:.3rem;margin-bottom:.5rem}
    label{font-size:.7rem;font-weight:500;color:#666;text-transform:uppercase;letter-spacing:.06em}
    input[type=text],input[type=url],input[type=color],textarea{width:100%;background:#fff;border:1.5px solid #E5E0D8;border-radius:8px;padding:.5rem .75rem;color:#1A1A1A;font-size:.8125rem;font-family:inherit;outline:none;transition:border-color .2s}
    input[type=color]{height:38px;padding:.2rem .4rem;cursor:pointer}
    input:focus,textarea:focus{border-color:#FF3B00}
    textarea{resize:vertical;min-height:60px}
    input[type=checkbox]{accent-color:#FF3B00;width:16px;height:16px}
    .btn-save{padding:.75rem 2rem;background:#FF3B00;color:#fff;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.875rem;border:none;border-radius:10px;cursor:pointer;margin-top:1rem}
    .btn-save:hover{background:#e03200}
    .toast{padding:.75rem 1.25rem;border-radius:10px;margin-bottom:1.5rem;font-size:.875rem;font-weight:500}
    .toast.ok{background:#f0fdf4;border:1px solid #86efac;color:#166534}
    .toast.err{background:#fef2f2;border:1px solid #fca5a5;color:#991b1b}
  </style>
</head><body>
<aside>
  <div class="logo">Mash<span>Bano</span></div>
  <nav>
    <a href="/admin">Dashboard</a><a href="/admin/hero">Hero</a><a href="/admin/story">Story</a>
    <a href="/admin/services" class="active">Services</a><a href="/admin/packages">Packages</a>
    <a href="/admin/portfolio">Portfolio</a><a href="/admin/testimonials">Testimonials</a>
    <a href="/admin/orders">Orders</a><a href="/admin/leads">Leads</a>
    <a href="/admin/blog">Blog</a><a href="/admin/seo">SEO</a>
    <a href="/admin/media">Media</a><a href="/admin/settings">Settings</a>
  </nav>
  <div class="sf"><a href="/">← View site</a></div>
</aside>
<main>
  <h1>Services Section</h1>
  <p class="sub">Edit all service cards — icon, name, description, link, visibility, section colors</p>
  {saved && <div class="toast ok">✓ Services saved!</div>}
  {error && <div class="toast err">⚠ {error}</div>}
  <form method="POST">
    <input type="hidden" name="service_count" value={services.length}/>
    <div class="card">
      <div class="card-title">Section Header</div>
      <div class="grid2">
        <div class="field"><label>Section Label</label><input type="text" name="section_label" value={c.section_label ?? '02 — What we do'}/></div>
        <div class="field"><label>Section Heading</label><input type="text" name="section_heading" value={c.section_heading ?? 'What we do'}/></div>
      </div>
      <div class="grid4" style="margin-top:.5rem">
        <div class="field"><label>Background</label><input type="color" name="bg_color" value={c.bg_color ?? '#F7F5F2'}/></div>
        <div class="field"><label>Card Background</label><input type="color" name="card_bg" value={c.card_bg ?? '#ffffff'}/></div>
        <div class="field"><label>Text Color</label><input type="color" name="text_color" value={c.text_color ?? '#1A1A1A'}/></div>
        <div class="field"><label>Accent Color</label><input type="color" name="accent_color" value={c.accent_color ?? '#FF3B00'}/></div>
      </div>
    </div>
    {services.map((svc: any, i: number) => (
      <div class="svc-card">
        <div class="svc-header">
          <span class="svc-num">{svc.num ?? String(i+1).padStart(2,'0')}</span>
          <label class="toggle"><input type="checkbox" name={`active_${i}`} checked={svc.is_active !== false}/> Active</label>
        </div>
        <div class="grid3">
          <div class="field"><label>Icon (emoji/symbol)</label><input type="text" name={`icon_${i}`} value={svc.icon ?? ''}/></div>
          <div class="field"><label>Service Name</label><input type="text" name={`name_${i}`} value={svc.name ?? ''}/></div>
          <div class="field"><label>Page Link</label><input type="text" name={`href_${i}`} value={svc.href ?? ''}/></div>
        </div>
        <div class="field"><label>Description</label><textarea name={`desc_${i}`}>{svc.desc ?? ''}</textarea></div>
      </div>
    ))}
    <button type="submit" class="btn-save">Save Services →</button>
  </form>
</main>
</body></html>
