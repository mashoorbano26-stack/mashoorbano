---
// src/pages/admin/settings.astro
// Controls: site_content WHERE page='settings' AND section='global'
export const prerender = false;
import { makeServerClient, supabaseAdmin } from '@/lib/supabase';
const supabase = makeServerClient(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/admin/login');

let saved = false; let error = '';
if (Astro.request.method === 'POST') {
  const f = await Astro.request.formData();
  const content = {
    company_name:   f.get('company_name')?.toString() ?? 'MashoorBano',
    tagline:        f.get('tagline')?.toString() ?? '',
    address:        f.get('address')?.toString() ?? '',
    phone:          f.get('phone')?.toString() ?? '',
    whatsapp:       f.get('whatsapp')?.toString() ?? '',
    email:          f.get('email')?.toString() ?? '',
    gst_number:     f.get('gst_number')?.toString() ?? '',
    instagram_url:  f.get('instagram_url')?.toString() ?? '',
    linkedin_url:   f.get('linkedin_url')?.toString() ?? '',
    youtube_url:    f.get('youtube_url')?.toString() ?? '',
    twitter_url:    f.get('twitter_url')?.toString() ?? '',
    calendly_url:   f.get('calendly_url')?.toString() ?? '',
    google_analytics_id: f.get('google_analytics_id')?.toString() ?? '',
    brand_accent:   f.get('brand_accent')?.toString() ?? '#FF3B00',
    brand_bg:       f.get('brand_bg')?.toString() ?? '#F7F5F2',
    navbar_bg:      f.get('navbar_bg')?.toString() ?? '#F7F5F2',
    footer_bg:      f.get('footer_bg')?.toString() ?? '#1A1A1A',
  };
  const { error: e } = await supabaseAdmin.from('site_content').upsert({ page:'settings', section:'global', content, updated_at: new Date().toISOString() }, { onConflict:'page,section' });
  if (e) error = e.message; else saved = true;
}
const { data } = await supabaseAdmin.from('site_content').select('content').eq('page','settings').eq('section','global').single();
const c = (data?.content as Record<string,string>) ?? {};
---
<!DOCTYPE html><html lang="en"><head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Settings — MashoorBano Admin</title><meta name="robots" content="noindex,nofollow"/>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{background:#F7F5F2;color:#1A1A1A;font-family:Inter,sans-serif;min-height:100vh;display:flex}
    aside{width:220px;min-height:100vh;background:#fff;border-right:1px solid #E5E0D8;display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto;flex-shrink:0}
    .logo{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1rem;padding:1.25rem 1rem;border-bottom:1px solid #E5E0D8}
    .logo span{color:#FF3B00}
    nav a{display:block;padding:.45rem 1rem;color:#888;font-size:.8125rem;text-decoration:none;transition:all .15s;border-left:2px solid transparent}
    nav a:hover{color:#1A1A1A;background:#F7F5F2}
    nav a.active{color:#FF3B00;border-left-color:#FF3B00;background:#fff5f3}
    .sf{padding:.75rem 1rem;border-top:1px solid #E5E0D8;margin-top:auto}
    .sf a{font-size:.75rem;color:#888;text-decoration:none}
    main{flex:1;padding:2rem;max-width:900px}
    h1{font-family:'Space Grotesk',sans-serif;font-size:1.375rem;font-weight:700;margin-bottom:.25rem;letter-spacing:-.02em}
    .sub{color:#888;font-size:.8125rem;margin-bottom:2rem}
    .card{background:#fff;border:1px solid #E5E0D8;border-radius:16px;padding:1.75rem;margin-bottom:1.5rem}
    .card-title{font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:.9375rem;margin-bottom:1.25rem;display:flex;align-items:center;gap:.5rem}
    .card-title::before{content:'';width:3px;height:1rem;background:#FF3B00;border-radius:2px}
    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .grid4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:.75rem}
    .field{display:flex;flex-direction:column;gap:.375rem;margin-bottom:.75rem}
    label{font-size:.75rem;font-weight:500;color:#666;text-transform:uppercase;letter-spacing:.06em}
    input[type=text],input[type=url],input[type=email],input[type=color]{width:100%;background:#F7F5F2;border:1.5px solid #E5E0D8;border-radius:10px;padding:.625rem .875rem;color:#1A1A1A;font-size:.875rem;font-family:inherit;outline:none;transition:border-color .2s}
    input[type=color]{height:42px;padding:.25rem .5rem;cursor:pointer}
    input:focus{border-color:#FF3B00}
    .btn-save{padding:.75rem 2rem;background:#FF3B00;color:#fff;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.875rem;border:none;border-radius:10px;cursor:pointer}
    .btn-save:hover{background:#e03200}
    .toast{padding:.75rem 1.25rem;border-radius:10px;margin-bottom:1.5rem;font-size:.875rem;font-weight:500}
    .toast.ok{background:#f0fdf4;border:1px solid #86efac;color:#166534}
    .toast.err{background:#fef2f2;border:1px solid #fca5a5;color:#991b1b}
    .hint{font-size:.7rem;color:#aaa;margin-top:.2rem}
  </style>
</head><body>
<aside>
  <div class="logo">Mash<span>Bano</span></div>
  <nav>
    <a href="/admin">Dashboard</a><a href="/admin/hero">Hero</a><a href="/admin/story">Story</a>
    <a href="/admin/services">Services</a><a href="/admin/packages">Packages</a>
    <a href="/admin/portfolio">Portfolio</a><a href="/admin/testimonials">Testimonials</a>
    <a href="/admin/orders">Orders</a><a href="/admin/leads">Leads</a>
    <a href="/admin/blog">Blog</a><a href="/admin/seo">SEO</a>
    <a href="/admin/media">Media</a><a href="/admin/settings" class="active">Settings</a>
  </nav>
  <div class="sf"><a href="/">← View site</a></div>
</aside>
<main>
  <h1>Site Settings</h1>
  <p class="sub">Business info, contact details, social links, brand colors — used across the entire site</p>
  {saved && <div class="toast ok">✓ Settings saved! Footer, contact section, and navbar updated.</div>}
  {error && <div class="toast err">⚠ {error}</div>}
  <form method="POST">
    <div class="card">
      <div class="card-title">Business Information</div>
      <div class="grid2">
        <div class="field"><label>Company Name</label><input type="text" name="company_name" value={c.company_name ?? 'MashoorBano'}/><span class="hint">Appears in navbar, footer, emails</span></div>
        <div class="field"><label>Tagline</label><input type="text" name="tagline" value={c.tagline ?? 'Brands that actually hit.'}/></div>
        <div class="field"><label>Email</label><input type="email" name="email" value={c.email ?? 'hello@MashoorBano.com'}/></div>
        <div class="field"><label>Phone</label><input type="text" name="phone" value={c.phone ?? '+91 78147 18340'}/></div>
        <div class="field"><label>WhatsApp Number (with country code, no +)</label><input type="text" name="whatsapp" value={c.whatsapp ?? '917814718340'} placeholder="917814718340"/></div>
        <div class="field"><label>GST Number</label><input type="text" name="gst_number" value={c.gst_number ?? ''} placeholder="27AAAAA0000A1Z5"/></div>
      </div>
      <div class="field"><label>Address</label><input type="text" name="address" value={c.address ?? 'India'}/></div>
    </div>
    <div class="card">
      <div class="card-title">Social Media Links</div>
      <div class="grid2">
        <div class="field"><label>Instagram URL</label><input type="url" name="instagram_url" value={c.instagram_url ?? 'https://instagram.com/MashoorBano'}/></div>
        <div class="field"><label>LinkedIn URL</label><input type="url" name="linkedin_url" value={c.linkedin_url ?? 'https://linkedin.com/company/MashoorBano'}/></div>
        <div class="field"><label>YouTube URL</label><input type="url" name="youtube_url" value={c.youtube_url ?? ''} placeholder="https://youtube.com/@MashoorBano"/></div>
        <div class="field"><label>Twitter/X URL</label><input type="url" name="twitter_url" value={c.twitter_url ?? ''} placeholder="https://twitter.com/MashoorBano"/></div>
        <div class="field"><label>Calendly URL</label><input type="url" name="calendly_url" value={c.calendly_url ?? 'https://calendly.com/MashoorBano/strategy'}/></div>
        <div class="field"><label>Google Analytics ID</label><input type="text" name="google_analytics_id" value={c.google_analytics_id ?? ''} placeholder="G-XXXXXXXXXX"/></div>
      </div>
    </div>
    <div class="card">
      <div class="card-title">Brand Colors (site-wide)</div>
      <div class="grid4">
        <div class="field"><label>Accent / CTA Color</label><input type="color" name="brand_accent" value={c.brand_accent ?? '#FF3B00'}/></div>
        <div class="field"><label>Page Background</label><input type="color" name="brand_bg" value={c.brand_bg ?? '#F7F5F2'}/></div>
        <div class="field"><label>Navbar Background</label><input type="color" name="navbar_bg" value={c.navbar_bg ?? '#F7F5F2'}/></div>
        <div class="field"><label>Footer Background</label><input type="color" name="footer_bg" value={c.footer_bg ?? '#1A1A1A'}/></div>
      </div>
    </div>
    <button type="submit" class="btn-save">Save Settings →</button>
  </form>
</main>
</body></html>
