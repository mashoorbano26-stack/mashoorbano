---
export const prerender = false;
import { makeServerClient, supabaseAdmin } from '@/lib/supabase';
const supabase = makeServerClient(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/admin/login');
let saved=false,error='';
if(Astro.request.method==='POST'){
  const f=await Astro.request.formData();
  const act=f.get('_action')?.toString();
  const slug=(f.get('title')?.toString()??'').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'');
  if(act==='save'){
    const id=f.get('id')?.toString();
    const row={title:f.get('title')?.toString()??'',slug:f.get('slug')?.toString()||slug,excerpt:f.get('excerpt')?.toString()??'',body:f.get('body')?.toString()??'',cover_image_url:f.get('cover_image_url')?.toString()||null,tags:(f.get('tags')?.toString()??'').split(',').map((t:string)=>t.trim()).filter(Boolean),seo_title:f.get('seo_title')?.toString()??'',seo_description:f.get('seo_description')?.toString()??'',is_published:f.get('is_published')==='on',published_at:f.get('is_published')==='on'?new Date().toISOString():null,updated_at:new Date().toISOString()};
    if(id){const{error:e}=await supabaseAdmin.from('blog_posts').update(row).eq('id',id);if(e)error=e.message;else saved=true;}
    else{const{error:e}=await supabaseAdmin.from('blog_posts').insert(row);if(e)error=e.message;else saved=true;}
  }
}
const{data:posts}=await supabaseAdmin.from('blog_posts').select('*').order('created_at',{ascending:false});
const rows=posts??[];
---
<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"/><title>Blog — Mashurban Admin</title><meta name="robots" content="noindex,nofollow"/><link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet"/>
<style>*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}body{background:#F7F5F2;color:#1A1A1A;font-family:Inter,sans-serif;min-height:100vh;display:flex}aside{width:220px;min-height:100vh;background:#fff;border-right:1px solid #E5E0D8;display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto;flex-shrink:0}.logo{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1rem;padding:1.25rem 1rem;border-bottom:1px solid #E5E0D8}.logo span{color:#FF3B00}nav a{display:block;padding:.45rem 1rem;color:#888;font-size:.8125rem;text-decoration:none;border-left:2px solid transparent;transition:all .15s}nav a:hover{color:#1A1A1A;background:#F7F5F2}nav a.active{color:#FF3B00;border-left-color:#FF3B00;background:#fff5f3}.sf{padding:.75rem 1rem;border-top:1px solid #E5E0D8;margin-top:auto}.sf a{font-size:.75rem;color:#888;text-decoration:none}main{flex:1;padding:2rem;max-width:900px}h1{font-family:'Space Grotesk',sans-serif;font-size:1.375rem;font-weight:700;margin-bottom:.25rem}.sub{color:#888;font-size:.8125rem;margin-bottom:2rem}.card{background:#fff;border:1px solid #E5E0D8;border-radius:16px;padding:1.5rem;margin-bottom:1rem}.new-form{background:#fff5f3;border:1.5px dashed #FF3B00;border-radius:16px;padding:1.5rem;margin-bottom:1.5rem}.new-title{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.9375rem;color:#FF3B00;margin-bottom:1rem}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:.75rem}.field{display:flex;flex-direction:column;gap:.3rem;margin-bottom:.5rem}label{font-size:.7rem;font-weight:500;color:#666;text-transform:uppercase;letter-spacing:.06em}input[type=text],input[type=url],textarea{width:100%;background:#F7F5F2;border:1.5px solid #E5E0D8;border-radius:8px;padding:.5rem .75rem;color:#1A1A1A;font-size:.8125rem;font-family:inherit;outline:none;transition:border-color .2s}input:focus,textarea:focus{border-color:#FF3B00}textarea{resize:vertical}.check-label{display:flex;align-items:center;gap:.375rem;font-size:.8125rem;color:#555;cursor:pointer;margin:.5rem 0}input[type=checkbox]{accent-color:#FF3B00}.btn-save{padding:.55rem 1.25rem;background:#FF3B00;color:#fff;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.8125rem;border:none;border-radius:8px;cursor:pointer;margin-top:.75rem}.toast{padding:.75rem 1.25rem;border-radius:10px;margin-bottom:1rem;font-size:.875rem;font-weight:500}.toast.ok{background:#f0fdf4;border:1px solid #86efac;color:#166534}.toast.err{background:#fef2f2;border:1px solid #fca5a5;color:#991b1b}details summary{cursor:pointer;list-style:none}.pub-badge{display:inline-block;padding:.15rem .5rem;border-radius:999px;font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em}.hint{font-size:.7rem;color:#aaa;margin-top:.2rem}</style>
</head><body>
<aside><div class="logo">Mash<span>urban</span></div><nav><a href="/admin">Dashboard</a><a href="/admin/header">Header</a><a href="/admin/hero">Hero</a><a href="/admin/story">Story</a><a href="/admin/services">Services</a><a href="/admin/packages">Packages</a><a href="/admin/portfolio">Portfolio</a><a href="/admin/testimonials">Testimonials</a><a href="/admin/orders">Orders</a><a href="/admin/leads">Leads</a><a href="/admin/blog" class="active">Blog</a><a href="/admin/seo">SEO</a><a href="/admin/media">Media</a><a href="/admin/settings">Settings</a></nav><div class="sf"><a href="/">← View site</a></div></aside>
<main><h1>Blog</h1><p class="sub">Write and manage blog posts</p>
{saved&&<div class="toast ok">✓ Post saved!</div>}{error&&<div class="toast err">⚠ {error}</div>}
<div class="new-form"><div class="new-title">+ New Post</div>
<form method="POST"><input type="hidden" name="_action" value="save"/>
  <div class="field"><label>Title</label><input type="text" name="title" placeholder="How We Got 4× ROAS for a D2C Brand" required/></div>
  <div class="field"><label>Slug (auto-generated if empty)</label><input type="text" name="slug" placeholder="leave blank to auto-generate"/><span class="hint">URL: /blog/your-slug</span></div>
  <div class="field"><label>Excerpt (shown on blog listing)</label><textarea name="excerpt" rows="2" placeholder="A short summary of the post..."></textarea></div>
  <div class="field"><label>Body (Markdown or HTML)</label><textarea name="body" rows="10" placeholder="Write your full post here..."></textarea></div>
  <div class="grid2">
    <div class="field"><label>Cover Image URL</label><input type="url" name="cover_image_url" placeholder="https://..."/></div>
    <div class="field"><label>Tags (comma-separated)</label><input type="text" name="tags" placeholder="meta ads, case study, d2c"/></div>
    <div class="field"><label>SEO Title</label><input type="text" name="seo_title" placeholder="Overrides post title in search results"/></div>
    <div class="field"><label>SEO Description</label><input type="text" name="seo_description" placeholder="Max 160 chars"/></div>
  </div>
  <label class="check-label"><input type="checkbox" name="is_published"/> Publish immediately</label>
  <button type="submit" class="btn-save">Save Post</button>
</form></div>
{rows.map((p:any)=>(
  <div class="card"><details>
    <summary style="display:flex;justify-content:space-between;align-items:center">
      <span style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.9375rem">{p.title}</span>
      <span class="pub-badge" style={p.is_published?'background:#f0fdf4;color:#166534;border:1px solid #86efac':'background:#f3f4f6;color:#888;border:1px solid #e5e7eb'}>{p.is_published?'Published':'Draft'}</span>
    </summary>
    <form method="POST" style="margin-top:1rem"><input type="hidden" name="_action" value="save"/><input type="hidden" name="id" value={p.id}/>
      <div class="field"><label>Title</label><input type="text" name="title" value={p.title}/></div>
      <div class="field"><label>Slug</label><input type="text" name="slug" value={p.slug}/></div>
      <div class="field"><label>Excerpt</label><textarea name="excerpt" rows="2">{p.excerpt??''}</textarea></div>
      <div class="field"><label>Body</label><textarea name="body" rows="10">{p.body??''}</textarea></div>
      <div class="grid2">
        <div class="field"><label>Cover Image URL</label><input type="url" name="cover_image_url" value={p.cover_image_url??''}/></div>
        <div class="field"><label>Tags</label><input type="text" name="tags" value={Array.isArray(p.tags)?p.tags.join(', '):''}/></div>
        <div class="field"><label>SEO Title</label><input type="text" name="seo_title" value={p.seo_title??''}/></div>
        <div class="field"><label>SEO Description</label><input type="text" name="seo_description" value={p.seo_description??''}/></div>
      </div>
      <label class="check-label"><input type="checkbox" name="is_published" checked={p.is_published}/> Published</label>
      <button type="submit" class="btn-save">Save Changes</button>
    </form>
  </details></div>
))}
</main></body></html>
