---
// src/pages/admin/orders.astro
export const prerender = false;
import { makeServerClient, getAdmin } from '@/lib/supabase';
const supabase = makeServerClient(Astro.cookies);
const supabaseAdmin = getAdmin(Astro.locals);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/admin/login');

let saved = false; let error = '';
if (Astro.request.method === 'POST') {
  const f = await Astro.request.formData();
  if (f.get('_action') === 'status') {
    const { error: e } = await supabaseAdmin.from('orders').update({ status: f.get('status')?.toString(), updated_at: new Date().toISOString() }).eq('id', f.get('id')?.toString());
    if (e) error = e.message; else saved = true;
  }
}

const statusFilter = Astro.url.searchParams.get('status') ?? '';
let query = supabaseAdmin.from('orders').select('*').order('created_at', { ascending: false }).limit(50);
if (statusFilter) query = query.eq('status', statusFilter);
const { data: orders } = await query;
const rows = orders ?? [];

const STATUS_COLORS: Record<string,string> = {
  pending: '#f59e0b', paid: '#10b981', processing: '#3b82f6',
  delivered: '#06b6d4', failed: '#ef4444', refunded: '#6b7280',
};
---
<!DOCTYPE html><html lang="en"><head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Orders — MashoorBano Admin</title><meta name="robots" content="noindex,nofollow"/>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{background:#F7F5F2;color:#1A1A1A;font-family:Inter,sans-serif;min-height:100vh;display:flex}
    aside{width:220px;min-height:100vh;background:#fff;border-right:1px solid #E5E0D8;display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto;flex-shrink:0}
    .logo{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1rem;padding:1.25rem 1rem;border-bottom:1px solid #E5E0D8}
    .logo span{color:#FF3B00}
    nav a{display:block;padding:.45rem 1rem;color:#888;font-size:.8125rem;text-decoration:none;border-left:2px solid transparent;transition:all .15s}
    nav a:hover{color:#1A1A1A;background:#F7F5F2}
    nav a.active{color:#FF3B00;border-left-color:#FF3B00;background:#fff5f3}
    .sf{padding:.75rem 1rem;border-top:1px solid #E5E0D8;margin-top:auto}
    .sf a{font-size:.75rem;color:#888;text-decoration:none}
    main{flex:1;padding:2rem}
    h1{font-family:'Space Grotesk',sans-serif;font-size:1.375rem;font-weight:700;margin-bottom:.25rem}
    .sub{color:#888;font-size:.8125rem;margin-bottom:1.5rem}
    .filters{display:flex;gap:.5rem;margin-bottom:1.5rem;flex-wrap:wrap}
    .filter-btn{padding:.375rem .875rem;border-radius:999px;font-size:.75rem;font-weight:600;text-decoration:none;border:1.5px solid #E5E0D8;color:#555;transition:all .15s}
    .filter-btn:hover,.filter-btn.active{border-color:#FF3B00;color:#FF3B00;background:#fff5f3}
    table{width:100%;border-collapse:collapse;background:#fff;border-radius:16px;overflow:hidden;border:1px solid #E5E0D8;font-size:.8125rem}
    thead{background:#F7F5F2}
    th{padding:.75rem 1rem;text-align:left;font-size:.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:#888;white-space:nowrap}
    td{padding:.875rem 1rem;border-top:1px solid #F0EDE8;vertical-align:top}
    tr:hover td{background:#fafaf9}
    .status-badge{display:inline-block;padding:.2rem .625rem;border-radius:999px;font-size:.65rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase}
    .order-num{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.8125rem}
    .customer{font-weight:500}
    .email{font-size:.75rem;color:#888}
    .amount{font-family:'Space Grotesk',sans-serif;font-weight:700;color:#1A1A1A}
    select.status-sel{background:#F7F5F2;border:1.5px solid #E5E0D8;border-radius:6px;padding:.25rem .5rem;font-size:.75rem;font-family:inherit;outline:none;cursor:pointer}
    .btn-upd{padding:.25rem .6rem;background:#FF3B00;color:#fff;border:none;border-radius:6px;font-size:.7rem;cursor:pointer;font-weight:600}
    .toast{padding:.75rem 1.25rem;border-radius:10px;margin-bottom:1rem;font-size:.875rem;font-weight:500}
    .toast.ok{background:#f0fdf4;border:1px solid #86efac;color:#166534}
    .toast.err{background:#fef2f2;border:1px solid #fca5a5;color:#991b1b}
    .empty{text-align:center;padding:3rem;color:#888}
  </style>
</head><body>
<aside>
  <div class="logo">Mashoor<span>Bano</span></div>
  <nav>
    <a href="/admin">Dashboard</a><a href="/admin/header">Header</a><a href="/admin/hero">Hero</a><a href="/admin/story">Story</a>
    <a href="/admin/services">Services</a><a href="/admin/packages">Packages</a>
    <a href="/admin/portfolio">Portfolio</a><a href="/admin/testimonials">Testimonials</a>
    <a href="/admin/orders" class="active">Orders</a><a href="/admin/leads">Leads</a>
    <a href="/admin/blog">Blog</a><a href="/admin/seo">SEO</a>
    <a href="/admin/media">Media</a><a href="/admin/settings">Settings</a>
  </nav>
  <div class="sf"><a href="/">← View site</a></div>
</aside>
<main>
  <h1>Orders</h1>
  <p class="sub">View and update payment orders</p>
  {saved && <div class="toast ok">✓ Status updated!</div>}
  {error && <div class="toast err">⚠ {error}</div>}
  <div class="filters">
    <a href="/admin/orders" class={`filter-btn ${!statusFilter ? 'active' : ''}`}>All</a>
    {['pending','paid','processing','delivered','failed','refunded'].map(s => (
      <a href={`/admin/orders?status=${s}`} class={`filter-btn ${statusFilter===s ? 'active' : ''}`} style={statusFilter===s ? `border-color:${STATUS_COLORS[s]};color:${STATUS_COLORS[s]}` : ''}>{s}</a>
    ))}
  </div>
  <table>
    <thead><tr><th>Order #</th><th>Customer</th><th>Items</th><th>Total</th><th>Gateway</th><th>Status</th><th>Date</th><th>Update</th></tr></thead>
    <tbody>
      {rows.length === 0 && <tr><td colspan="8" class="empty">No orders found</td></tr>}
      {rows.map((o: any) => (
        <tr>
          <td><span class="order-num">{o.order_number}</span></td>
          <td><div class="customer">{o.customer_name}</div><div class="email">{o.customer_email}</div></td>
          <td style="max-width:160px;font-size:.75rem;color:#555">{Array.isArray(o.items) ? o.items.map((i:any)=>i.name).join(', ') : '—'}</td>
          <td><span class="amount">₹{Number(o.total).toLocaleString('en-IN')}</span></td>
          <td style="font-size:.75rem;text-transform:capitalize">{o.payment_gateway ?? '—'}</td>
          <td><span class="status-badge" style={`background:${STATUS_COLORS[o.status] ?? '#888'}22;color:${STATUS_COLORS[o.status] ?? '#888'};border:1px solid ${STATUS_COLORS[o.status] ?? '#888'}44`}>{o.status}</span></td>
          <td style="font-size:.75rem;color:#888;white-space:nowrap">{new Date(o.created_at).toLocaleDateString('en-IN')}</td>
          <td>
            <form method="POST" style="display:flex;gap:.375rem;align-items:center">
              <input type="hidden" name="_action" value="status"/>
              <input type="hidden" name="id" value={o.id}/>
              <select name="status" class="status-sel">
                {['pending','paid','processing','delivered','failed','refunded'].map(s => <option value={s} selected={o.status===s}>{s}</option>)}
              </select>
              <button type="submit" class="btn-upd">✓</button>
            </form>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</main>
</body></html>
