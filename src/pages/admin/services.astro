---
// src/pages/admin/services.astro
// Full control: section bg, heading, subheading, card bg/text/hover colours
export const prerender = false;
import { makeServerClient, getAdmin } from '@/lib/supabase';
const supabase = makeServerClient(Astro.cookies);
const supabaseAdmin = getAdmin(Astro.locals);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/admin/login');

let saved = false; let errMsg = '';

if (Astro.request.method === 'POST') {
  const f = await Astro.request.formData();
  const g = (k: string, d = '') => f.get(k)?.toString() ?? d;
  const count = parseInt(g('svc_count','0'));
  const services = Array.from({ length: count }, (_, i) => ({
    num:        g(`svc_num_${i}`,  String(i+1).padStart(2,'0')),
    icon:       g(`svc_icon_${i}`, '◆'),
    name:       g(`svc_name_${i}`),
    desc:       g(`svc_desc_${i}`),
    href:       g(`svc_href_${i}`, '/services'),
    image_url:  g(`svc_img_${i}`) || undefined,
    is_active:  g(`svc_active_${i}`) === 'on',
    sort_order: i,
  })).filter(s => s.name);
  const content = {
    section_bg:              g('section_bg','#0A0A0A'),
    heading:                 g('heading','What We Do'),
    subheading:              g('subheading','Six services. One agency. Zero excuses.'),
    label:                   g('label','02 — Services'),
    heading_color:           g('heading_color','#F5F5F0'),
    subheading_color:        g('subheading_color','#888888'),
    default_card_bg:         g('default_card_bg','#141414'),
    default_card_text:       g('default_card_text','#F5F5F0'),
    default_card_hover_bg:   g('default_card_hover_bg','#FF3B00'),
    default_card_hover_text: g('default_card_hover_text','#FFFFFF'),
    services,
  };
  const { error: e } = await supabaseAdmin.from('site_content').upsert(
    { page:'home', section:'services', content, updated_at: new Date().toISOString() },
    { onConflict:'page,section' });
  saved = !e; errMsg = e?.message ?? '';
}

const { data } = await supabaseAdmin.from('site_content').select('content').eq('page','home').eq('section','services').single();
const cfg = (data?.content as any) ?? {};
const v = (k: string, d: string) => cfg[k] ?? d;
const svcs: any[] = cfg.services ?? [
  { num:'01',icon:'⬡',name:'Website Design', desc:'Fast, SEO-ready sites that convert.', href:'/services/websites',is_active:true },
  { num:'02',icon:'◈',name:'Merchandise',     desc:'Merch your audience wants to wear.',  href:'/services/merchandise',is_active:true },
  { num:'03',icon:'▶',name:'Content Creation',desc:'Reels and content that stop the scroll.',href:'/services/content-creation',is_active:true },
  { num:'04',icon:'◉',name:'Meta Ads',        desc:'Facebook + Instagram campaigns.',       href:'/services/meta-ads',is_active:true },
  { num:'05',icon:'◎',name:'Google Ads',      desc:'Show up when your customer is looking.',href:'/services/google-ads',is_active:true },
  { num:'06',icon:'◆',name:'Brand Identity',  desc:'Logo, palette, typeface, voice.',       href:'/services/branding',is_active:true },
];

const DEFAULT_IMAGE_URLS = [
  'data:image/svg+xml;base64,',
  'data:image/svg+xml;base64,',
  'data:image/svg+xml;base64,',
  'data:image/svg+xml;base64,',
  'data:image/svg+xml;base64,',
  'data:image/svg+xml;base64,',
];
---
<!DOCTYPE html><html lang="en"><head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Services — MashoorBano Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:#F7F5F2;color:#1A1A1A;font-family:Inter,sans-serif;min-height:100vh;display:flex}
aside{width:220px;min-height:100vh;background:#fff;border-right:1px solid #E5E0D8;display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto;flex-shrink:0}
.logo{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1rem;padding:1.25rem 1rem;border-bottom:1px solid #E5E0D8}.logo span{color:#FF3B00}
nav a{display:block;padding:.45rem 1rem;color:#888;font-size:.8125rem;text-decoration:none;border-left:2px solid transparent}
nav a:hover{color:#1A1A1A;background:#F7F5F2}nav a.active{color:#FF3B00;border-left-color:#FF3B00;background:#fff5f3}
.sf{padding:.75rem 1rem;border-top:1px solid #E5E0D8;margin-top:auto}.sf a{font-size:.75rem;color:#888;text-decoration:none}
main{flex:1;padding:2rem;max-width:960px}
h1{font-family:'Space Grotesk',sans-serif;font-size:1.375rem;font-weight:700;margin-bottom:.25rem}
.sub{color:#888;font-size:.8125rem;margin-bottom:1.5rem}
.card{background:#fff;border:1px solid #E5E0D8;border-radius:16px;padding:1.75rem;margin-bottom:1.25rem}
.card-title{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.9375rem;margin-bottom:1.25rem;display:flex;align-items:center;gap:.5rem}
.card-title::before{content:'';width:3px;height:1rem;background:#FF3B00;border-radius:2px}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem}
.grid4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:.75rem}
.field{display:flex;flex-direction:column;gap:.375rem;margin-bottom:.75rem}
label{font-size:.7rem;font-weight:600;color:#666;text-transform:uppercase;letter-spacing:.06em}
input,textarea{width:100%;background:#F7F5F2;border:1.5px solid #E5E0D8;border-radius:10px;padding:.625rem .875rem;color:#1A1A1A;font-size:.875rem;font-family:inherit;outline:none;transition:border-color .2s}
input[type=color]{height:44px;padding:.3rem .5rem}input:focus,textarea:focus{border-color:#FF3B00}
.svc-item{background:#F7F5F2;border-radius:12px;padding:1rem;margin-bottom:.75rem}
.btn-save{padding:.875rem 2.5rem;background:#FF3B00;color:#fff;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.9375rem;border:none;border-radius:12px;cursor:pointer}
.btn-del{padding:.4rem .75rem;background:#fff;border:1px solid #ddd;color:#ef4444;border-radius:8px;font-size:.75rem;cursor:pointer}
.toast{padding:.875rem 1.25rem;border-radius:12px;margin-bottom:1.5rem;font-size:.875rem;font-weight:500}
.toast.ok{background:#f0fdf4;border:1px solid #86efac;color:#166534}
.toast.err{background:#fef2f2;border:1px solid #fca5a5;color:#991b1b}
</style>
</head><body>
<aside>
  <div class="logo">Mashoor<span>Bano</span></div>
  <nav>
    <a href="/admin">Dashboard</a><a href="/admin/header">Header</a>
    <a href="/admin/hero">Hero</a><a href="/admin/story">Story</a>
    <a href="/admin/services" class="active">Services</a><a href="/admin/packages">Packages</a>
    <a href="/admin/portfolio">Portfolio</a><a href="/admin/testimonials">Testimonials</a>
    <a href="/admin/orders">Orders</a><a href="/admin/leads">Leads</a>
    <a href="/admin/blog">Blog</a><a href="/admin/seo">SEO</a>
    <a href="/admin/media">Media</a><a href="/admin/settings">Settings</a>
  </nav>
  <div class="sf"><a href="/" target="_blank">← View site</a></div>
</aside>
<main>
  <h1>Services Section</h1>
  <p class="sub">Section background, card colours on default + hover, heading — all editable</p>
  {saved && <div class="toast ok">✓ Saved!</div>}
  {!saved && errMsg && <div class="toast err">⚠ {errMsg}</div>}
  <form method="POST">
    <div class="card">
      <div class="card-title">Heading & Copy</div>
      <div class="grid3">
        <div class="field"><label>Label</label><input type="text" name="label" value={v('label','02 — Services')}/></div>
        <div class="field"><label>Heading (one line)</label><input type="text" name="heading" value={v('heading','What We Do')}/></div>
        <div class="field"><label>Subheading</label><input type="text" name="subheading" value={v('subheading','Six services. One agency. Zero excuses.')}/></div>
      </div>
      <div class="grid4">
        <div class="field"><label>Section BG</label><input type="color" name="section_bg" value={v('section_bg','#0A0A0A')}/></div>
        <div class="field"><label>Heading Colour</label><input type="color" name="heading_color" value={v('heading_color','#F5F5F0')}/></div>
        <div class="field"><label>Subheading Colour</label><input type="color" name="subheading_color" value={v('subheading_color','#888888')}/></div>
      </div>
    </div>
    <div class="card">
      <div class="card-title">Card Colours (default for all cards)</div>
      <div class="grid4">
        <div class="field"><label>Card BG</label><input type="color" name="default_card_bg" value={v('default_card_bg','#141414')}/></div>
        <div class="field"><label>Card Text</label><input type="color" name="default_card_text" value={v('default_card_text','#F5F5F0')}/></div>
        <div class="field"><label>Hover BG</label><input type="color" name="default_card_hover_bg" value={v('default_card_hover_bg','#FF3B00')}/></div>
        <div class="field"><label>Hover Text</label><input type="color" name="default_card_hover_text" value={v('default_card_hover_text','#FFFFFF')}/></div>
      </div>
    </div>
    <div class="card">
      <div class="card-title">Services</div>
      <div id="svcList">
        {svcs.map((s: any, i: number) => (
          <div class="svc-item">
            <div class="grid4" style="margin-bottom:.5rem">
              <div class="field" style="margin:0"><label>No.</label><input type="text" name={`svc_num_${i}`} value={s.num}/></div>
              <div class="field" style="margin:0"><label>Icon</label><input type="text" name={`svc_icon_${i}`} value={s.icon}/></div>
              <div class="field" style="grid-column:span 2;margin:0"><label>Name</label><input type="text" name={`svc_name_${i}`} value={s.name}/></div>
            </div>
            <div class="field" style="margin-bottom:.5rem"><label>Description</label><input type="text" name={`svc_desc_${i}`} value={s.desc}/></div>
            <div class="grid2">
              <div class="field" style="margin:0"><label>Link</label><input type="text" name={`svc_href_${i}`} value={s.href}/></div>
              <div class="field" style="margin:0;flex-direction:row;align-items:center;gap:.5rem;padding-top:1.5rem">
                <input type="checkbox" name={`svc_active_${i}`} checked={s.is_active !== false} style="width:auto;accent-color:#FF3B00"/>
                <label style="text-transform:none;font-size:.8125rem;color:#444;letter-spacing:0">Active</label>
              </div>
            </div>
            <div class="field" style="margin-top:.5rem">
              <label>Thumbnail Image URL</label>
              <input type="text" name={`svc_img_${i}`} value={s.image_url || DEFAULT_IMAGE_URLS[i] || ''} placeholder="data:image/svg+xml;base64,… or https://…"/>
              <span style="font-size:.65rem;color:#aaa;margin-top:.25rem;">Pre-filled with built-in illustration. Paste any image URL or leave as-is.</span>
            </div>
          </div>
        ))}
      </div>
      <input type="hidden" name="svc_count" id="svcCount" value={svcs.length}/>
    </div>
    <button type="submit" class="btn-save">Save Services →</button>
  </form>
</main>
</body></html>
