---
// src/components/sections/Packages.astro
// Fetches live packages from Supabase `packages` table — managed via admin panel.
import { supabaseAdmin } from '@/lib/supabase';

interface Package {
  id: string;
  name: string;
  tagline: string | null;
  price_inr: number;
  price_usd: number | null;
  features: string[];
  is_popular: boolean;
}

let packages: Package[] = [];
try {
  const { data } = await supabaseAdmin
    .from('packages')
    .select('id, name, tagline, price_inr, price_usd, features, is_popular')
    .eq('is_active', true)
    .order('sort_order', { ascending: true });
  if (data) packages = data as Package[];
} catch {}

// Fallback defaults
if (!packages.length) {
  packages = [
    { id: 'starter',   name: 'Starter',    tagline: 'Perfect for new brands',          price_inr: 29999,  price_usd: 360,  features: ['5-page website','Mobile responsive','Basic SEO setup','Contact form','Google Analytics','1 month support'],                                                  is_popular: false },
    { id: 'growth',    name: 'Growth',     tagline: 'Most chosen by growing brands',    price_inr: 79999,  price_usd: 960,  features: ['10-page website','Social media setup','Meta ads (1 month)','4 content reels','Advanced SEO','WhatsApp integration','3 months support'],                  is_popular: true  },
    { id: 'fullstack', name: 'Full Stack', tagline: 'Complete digital presence',        price_inr: 149999, price_usd: 1800, features: ['Custom website','Brand identity kit','Merchandise design','Meta + Google ads 3mo','8 monthly reels','Dedicated account mgr','6 months support'], is_popular: false },
  ];
}

function formatINR(n: number) {
  return '₹' + n.toLocaleString('en-IN');
}
---

<section id="packages" class="bg-[#F7F5F2] py-24 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="section-label reveal">04 — Packages</div>

    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-6 mb-16">
      <h2 class="font-heading font-bold text-[clamp(40px,7vw,80px)] leading-[0.95] text-[#1A1A1A] reveal">
        Simple<br/>Pricing.
      </h2>
      <p class="text-sm text-[#666] max-w-xs leading-relaxed reveal reveal-delay-1">
        No hidden fees. No retainer traps. Pick a package, pay, and we get to work.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 reveal">
      {packages.map(pkg => (
        <div class={`relative flex flex-col rounded-2xl border-2 p-8 transition-all duration-300 hover:shadow-xl ${
          pkg.is_popular
            ? 'bg-[#1A1A1A] border-[#1A1A1A] shadow-lg scale-[1.02]'
            : 'bg-white border-[#E5E0D8] hover:border-[#FF3B00]'
        }`}>
          {pkg.is_popular && (
            <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-[#FF3B00] text-white text-[10px] font-bold tracking-[0.18em] uppercase px-4 py-1 rounded-full whitespace-nowrap">
              ★ Most Popular
            </span>
          )}

          <div class={`text-[10px] font-bold tracking-[0.18em] uppercase mb-6 ${pkg.is_popular ? 'text-[#FF3B00]' : 'text-[#AAA]'}`}>
            {pkg.name}
          </div>

          <div class={`font-heading font-bold text-5xl leading-none mb-1 ${pkg.is_popular ? 'text-white' : 'text-[#1A1A1A]'}`}>
            {formatINR(pkg.price_inr)}
          </div>
          <div class={`text-xs tracking-[0.1em] uppercase mb-8 ${pkg.is_popular ? 'text-[#888]' : 'text-[#AAA]'}`}>
            one-time · {pkg.tagline}
          </div>

          <ul class="space-y-0 flex-1 mb-8 list-none">
            {pkg.features.map((f: string) => (
              <li class={`flex gap-3 items-start py-3 border-b text-sm leading-relaxed ${
                pkg.is_popular ? 'border-[#2A2A2A] text-[#CCC]' : 'border-[#F0EDE8] text-[#555]'
              }`}>
                <span class="mt-0.5 flex-shrink-0 text-[#FF3B00]">→</span>
                {f}
              </li>
            ))}
          </ul>

          <a
            href="#contact"
            class={`w-full py-4 text-center text-xs font-heading font-bold tracking-widest uppercase transition-all block rounded-xl ${
              pkg.is_popular
                ? 'bg-[#FF3B00] text-white hover:bg-[#e03200]'
                : 'bg-[#F7F5F2] text-[#1A1A1A] border border-[#E5E0D8] hover:bg-[#FF3B00] hover:text-white hover:border-[#FF3B00]'
            }`}
          >
            Get Started
          </a>
        </div>
      ))}
    </div>

    <p class="text-center text-sm text-[#888] mt-8 reveal">
      Need something custom?
      <a href="#contact" class="text-[#1A1A1A] underline underline-offset-4 hover:text-[#FF3B00] transition-colors ml-1">
        Let's talk →
      </a>
    </p>
  </div>
</section>
