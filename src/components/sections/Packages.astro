---
// src/components/sections/Packages.astro
// Redesigned: centred heading, contrast hover colour change on packages, all from admin
import { supabaseAdmin } from '@/lib/supabase';

interface Package {
  id: string; name: string; tagline: string | null;
  price_inr: number; price_usd: number | null;
  features: string[]; is_popular: boolean;
  card_bg?: string; card_text?: string;
  card_hover_bg?: string; card_hover_text?: string;
}
interface PkgConfig {
  section_bg?: string; heading?: string; subheading?: string; label?: string;
  heading_color?: string; subheading_color?: string;
  default_card_bg?: string; default_card_text?: string;
  default_card_hover_bg?: string; default_card_hover_text?: string;
  popular_card_bg?: string;
}

let packages: Package[] = [];
let cfg: PkgConfig = {};

try {
  const { data } = await supabaseAdmin.from('packages')
    .select('id,name,tagline,price_inr,price_usd,features,is_popular,card_bg,card_text,card_hover_bg,card_hover_text')
    .eq('is_active', true).order('sort_order', { ascending: true });
  if (data) packages = data as Package[];
} catch {}

try {
  const { data } = await supabaseAdmin.from('site_content').select('content')
    .eq('page','home').eq('section','packages').single();
  if (data?.content) cfg = data.content as PkgConfig;
} catch {}

if (!packages.length) {
  packages = [
    { id:'starter',   name:'Starter',    tagline:'Perfect for new brands',       price_inr:29999,  price_usd:360,  features:['5-page website','Mobile responsive','Basic SEO','Contact form','Google Analytics','1 month support'],                          is_popular:false },
    { id:'growth',    name:'Growth',     tagline:'Most chosen by growing brands', price_inr:79999,  price_usd:960,  features:['10-page website','Social media setup','Meta ads 1 month','4 content reels','Advanced SEO','WhatsApp integration','3 months support'], is_popular:true  },
    { id:'fullstack', name:'Full Stack', tagline:'Complete digital presence',     price_inr:149999, price_usd:1800, features:['Custom website','Brand identity kit','Merch design','Meta + Google ads 3mo','8 monthly reels','Dedicated account mgr','6 months support'], is_popular:false },
  ];
}

const sectionBg  = cfg.section_bg          ?? '#F7F5F2';
const heading    = cfg.heading             ?? 'Simple Pricing';
const subheading = cfg.subheading          ?? 'No hidden fees. No retainer traps. Pick a package and we get to work.';
const label      = cfg.label              ?? '04 — Packages';
const hColor     = cfg.heading_color       ?? '#1A1A1A';
const sColor     = cfg.subheading_color    ?? '#888888';
const defCardBg  = cfg.default_card_bg     ?? '#FFFFFF';
const defCardTxt = cfg.default_card_text   ?? '#1A1A1A';
const defHoverBg = cfg.default_card_hover_bg   ?? '#1A1A1A';
const defHoverTxt= cfg.default_card_hover_text ?? '#F5F5F0';
const popBg      = cfg.popular_card_bg     ?? '#0A0A0A';

function formatINR(n: number) { return '₹' + n.toLocaleString('en-IN'); }
---

<section id="packages" style={`background:${sectionBg};padding:6rem 1.5rem;`}>
  <div style="max-width:1100px;margin:0 auto;">

    <!-- Centred heading -->
    <div style="text-align:center;margin-bottom:4rem;">
      <p style="font-size:.65rem;letter-spacing:.28em;text-transform:uppercase;color:#FF3B00;font-family:Inter,sans-serif;margin-bottom:1rem;">{label}</p>
      <h2 style={`font-family:'Space Grotesk',sans-serif;font-weight:900;font-size:clamp(2rem,5vw,3.5rem);color:${hColor};letter-spacing:-.03em;line-height:1;margin:0 0 1rem;white-space:nowrap;`}>{heading}</h2>
      <p style={`font-size:clamp(.8rem,1.2vw,1rem);color:${sColor};font-family:Inter,sans-serif;margin:0;max-width:520px;margin-left:auto;margin-right:auto;line-height:1.7;`}>{subheading}</p>
    </div>

    <!-- Package cards -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:1.25rem;">
      {packages.map(pkg => {
        const isPopular = pkg.is_popular;
        const cardBg    = isPopular ? popBg : (pkg.card_bg ?? defCardBg);
        const cardTxt   = isPopular ? '#F5F5F0' : (pkg.card_text ?? defCardTxt);
        const hoverBg   = pkg.card_hover_bg   ?? defHoverBg;
        const hoverTxt  = pkg.card_hover_text ?? defHoverTxt;
        return (
          <div
            class="pkg-card"
            data-hover-bg={hoverBg}
            data-hover-text={hoverTxt}
            data-default-bg={cardBg}
            data-default-text={cardTxt}
            data-popular={isPopular ? '1' : '0'}
            style={`position:relative;padding:2.5rem 2rem;border-radius:20px;display:flex;flex-direction:column;cursor:default;
              background:${cardBg};color:${cardTxt};
              border:1.5px solid ${isPopular ? '#FF3B00' : 'rgba(0,0,0,0.08)'};
              transition:background .3s,color .3s,border-color .3s,transform .25s,box-shadow .3s;`}>

            {isPopular && (
              <span style="position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:#FF3B00;color:#fff;font-size:.6rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;padding:.3rem 1rem;border-radius:999px;white-space:nowrap;">★ Most Popular</span>
            )}

            <div style={`font-size:.6rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;margin-bottom:1.5rem;color:${isPopular ? '#FF3B00' : '#AAA'};`}>{pkg.name}</div>

            <div style="font-family:'Space Grotesk',sans-serif;font-weight:900;font-size:2.75rem;line-height:1;margin-bottom:.25rem;">{formatINR(pkg.price_inr)}</div>
            <div style="font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;opacity:.55;margin-bottom:2rem;">one-time · {pkg.tagline}</div>

            <ul style="list-style:none;padding:0;margin:0 0 2rem;flex:1;">
              {pkg.features.map((feat: string) => (
                <li style="display:flex;gap:.75rem;align-items:flex-start;padding:.7rem 0;border-bottom:1px solid rgba(128,128,128,0.12);font-size:.8125rem;line-height:1.6;font-family:Inter,sans-serif;">
                  <span style="color:#FF3B00;flex-shrink:0;margin-top:.1rem;">→</span>
                  {feat}
                </li>
              ))}
            </ul>

            <a href="#contact"
              style={`display:block;text-align:center;padding:.875rem;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.7rem;letter-spacing:.16em;text-transform:uppercase;text-decoration:none;border-radius:10px;transition:all .25s;
                background:${isPopular ? '#FF3B00' : 'transparent'};
                color:${isPopular ? '#fff' : 'currentColor'};
                border:1.5px solid ${isPopular ? '#FF3B00' : 'rgba(128,128,128,0.3)'};`}
              onmouseover={`this.style.background='#FF3B00';this.style.color='#fff';this.style.borderColor='#FF3B00'`}
              onmouseout={isPopular ? `this.style.background='#FF3B00';this.style.color='#fff'` : `this.style.background='transparent';this.style.color='';this.style.borderColor='rgba(128,128,128,0.3)'`}>
              Get Started →
            </a>
          </div>
        );
      })}
    </div>

    <p style={`text-align:center;font-size:.8125rem;color:${sColor};margin-top:2rem;font-family:Inter,sans-serif;`}>
      Need something custom?
      <a href="#contact" style="color:#FF3B00;text-decoration:none;margin-left:.35rem;font-weight:600;">Let's talk →</a>
    </p>
  </div>
</section>

<script>
  document.querySelectorAll('.pkg-card').forEach(card => {
    const el = card as HTMLElement;
    const hBg   = el.dataset.hoverBg   ?? '#1A1A1A';
    const hTxt  = el.dataset.hoverText ?? '#F5F5F0';
    const dBg   = el.dataset.defaultBg ?? '#fff';
    const dTxt  = el.dataset.defaultText ?? '#1A1A1A';
    const isPop = el.dataset.popular === '1';
    if (isPop) return; // popular card keeps its style, no hover swap
    el.addEventListener('mouseenter', () => {
      el.style.background = hBg; el.style.color = hTxt;
      el.style.borderColor = hBg;
      el.style.transform = 'translateY(-4px)';
      el.style.boxShadow = '0 20px 60px rgba(0,0,0,0.18)';
    });
    el.addEventListener('mouseleave', () => {
      el.style.background = dBg; el.style.color = dTxt;
      el.style.borderColor = 'rgba(0,0,0,0.08)';
      el.style.transform = ''; el.style.boxShadow = '';
    });
  });
</script>
