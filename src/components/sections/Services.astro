---
// src/components/sections/Services.astro
// Image cards: upper half = thumbnail/icon visual, lower half = service name + desc + learn more
// All content + colours from admin panel
import { getAdmin } from '@/lib/supabase';
import { loadTheme } from '@/lib/theme';
const supabaseAdmin = getAdmin(Astro.locals);
const theme = await loadTheme(supabaseAdmin);

interface Service {
  icon: string; name: string; desc: string; href: string;
  num?: string; image_url?: string; is_active?: boolean; sort_order?: number;
  card_bg?: string; card_text?: string; card_hover_bg?: string; card_hover_text?: string;
}
interface ServicesCfg {
  services?: Service[];
  section_bg?: string; heading?: string; subheading?: string; label?: string;
  heading_color?: string; subheading_color?: string;
  default_card_bg?: string; default_card_text?: string;
  default_card_hover_bg?: string; default_card_hover_text?: string;
}

let services: Service[] = [];
let cfg: ServicesCfg = {};

try {
  const { data } = await supabaseAdmin
    .from('site_content').select('content')
    .eq('page', 'home').eq('section', 'services').single();
  if (data?.content) {
    cfg = data.content as ServicesCfg;
    services = (cfg.services ?? []).filter((s: Service) => s.is_active !== false);
  }
} catch {}

// ALWAYS use fallback if DB empty — hardcoded with all fields
if (!services.length) {
  services = [
    {
      num:'01', icon:'⬡', name:'Website Design',
      image_url:'data:image/svg+xml;base64,',
      desc:'Fast, SEO-ready websites that convert visitors into paying clients. No templates, no fluff — every pixel built for your brand.',
      href:'/services/websites',
    },
    {
      num:'02', icon:'◈', name:'Merchandise',
      image_url:'data:image/svg+xml;base64,',
      desc:'Custom T-shirts, caps, hoodies, and drops your audience actually wants to wear — designed to build community around your brand.',
      href:'/services/merchandise',
    },
    {
      num:'03', icon:'▶', name:'Content Creation',
      image_url:'data:image/svg+xml;base64,',
      desc:'Reels, shoots, scripting, editing — content engineered to stop the scroll, earn the follow, and turn viewers into buyers.',
      href:'/services/content-creation',
    },
    {
      num:'04', icon:'◉', name:'Meta Ads',
      image_url:'data:image/svg+xml;base64,',
      desc:'Facebook + Instagram campaigns built to spend less and return more. We target buyers, not just audiences.',
      href:'/services/meta-ads',
    },
    {
      num:'05', icon:'◎', name:'Google Ads',
      image_url:'data:image/svg+xml;base64,',
      desc:'Search, Display, YouTube — show up the moment your customer is looking. Smart bidding, zero wasted spend.',
      href:'/services/google-ads',
    },
    {
      num:'06', icon:'◆', name:'Brand Identity',
      image_url:'data:image/svg+xml;base64,',
      desc:'Logo, colour palette, typeface, brand voice — a complete identity system built to scale with your business for the next decade.',
      href:'/services/branding',
    },
  ];
}

const sectionBg  = theme.services_bg ?? cfg.section_bg ?? '#F7F5F2';
const heading    = cfg.heading                  ?? 'What We Do';
const subheading = cfg.subheading               ?? 'Six services. One agency. Zero excuses.';
const label      = cfg.label                   ?? '02 — Services';
const hColor     = theme.services_heading ?? cfg.heading_color ?? '#1A1A1A';
const sColor     = cfg.subheading_color         ?? '#888888';
const defCardBg  = theme.services_card_bg ?? cfg.default_card_bg ?? '#FFFFFF';
const defCardTxt = cfg.default_card_text        ?? '#1A1A1A';
const defHoverBg = cfg.default_card_hover_bg    ?? '#FF3B00';
const defHoverTxt= cfg.default_card_hover_text  ?? '#FFFFFF';

// Gradient colours per card for the thumbnail area (if no image uploaded)
const thumbGradients = [
  'linear-gradient(135deg,#FF3B00,#ff6b35)',
  'linear-gradient(135deg,#1a1a2e,#3a3a5c)',
  'linear-gradient(135deg,#11998e,#38ef7d)',
  'linear-gradient(135deg,#c94b4b,#e96c6c)',
  'linear-gradient(135deg,#1e3c72,#4286f4)',
  'linear-gradient(135deg,#373b44,#7b4f9e)',
];
---

<section id="services" style={`background:${sectionBg};padding:6rem 1.5rem;`}>
  <div style="max-width:1280px;margin:0 auto;">

    <!-- Centred heading — single line -->
    <div style="text-align:center;margin-bottom:4rem;">
      <p style="font-size:.65rem;letter-spacing:.28em;text-transform:uppercase;color:#FF3B00;font-family:Inter,sans-serif;margin-bottom:1rem;">{label}</p>
      <h2 style={`font-family:'Space Grotesk',sans-serif;font-weight:900;font-size:clamp(2rem,5vw,3.75rem);color:${hColor};letter-spacing:-.03em;line-height:1;margin:0 0 1rem;`}>{heading}</h2>
      <p style={`font-size:clamp(.8rem,1.2vw,1rem);color:${sColor};font-family:Inter,sans-serif;margin:0;`}>{subheading}</p>
    </div>

    <!-- IMAGE CARDS GRID -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;">
      {services.map((s, i) => (
        <a
          href={s.href}
          class="svc-card"
          data-hover-bg={s.card_hover_bg ?? defHoverBg}
          data-hover-text={s.card_hover_text ?? defHoverTxt}
          data-default-bg={s.card_bg ?? defCardBg}
          data-default-text={s.card_text ?? defCardTxt}
          style={`
            display:flex;flex-direction:column;
            text-decoration:none;border-radius:20px;overflow:hidden;
            background:${s.card_bg ?? defCardBg};
            color:${s.card_text ?? defCardTxt};
            border:1px solid #E5E0D8;
            transition:background .3s ease,color .3s ease,transform .25s ease,box-shadow .3s ease;
          `}
        >
          <!-- UPPER HALF: thumbnail / image -->
          <div class="svc-thumb" style={`
            position:relative;
            height:200px;
            overflow:hidden;
            background:${s.image_url ? 'transparent' : thumbGradients[i % thumbGradients.length]};
            flex-shrink:0;
          `}>
            {s.image_url ? (
              <img
                src={s.image_url}
                alt={s.name}
                style="width:100%;height:100%;object-fit:cover;display:block;transition:transform .45s ease;"
                class="svc-img"
              />
            ) : (
              <!-- Placeholder: large icon centred on gradient -->
              <div style="width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;">
                <div style="font-size:3.5rem;opacity:.9;line-height:1;">{s.icon}</div>
                <div style="font-size:.55rem;letter-spacing:.3em;text-transform:uppercase;color:rgba(255,255,255,.5);font-family:Inter,sans-serif;">{s.num}</div>
              </div>
            )}
            <!-- Number badge top-left -->
            <div style="position:absolute;top:1rem;left:1rem;font-size:.55rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.5);font-family:Inter,sans-serif;font-weight:600;">{s.num}</div>
            <!-- Hover overlay -->
            <div class="svc-overlay" style="position:absolute;inset:0;background:rgba(255,59,0,0);transition:background .3s ease;"></div>
          </div>

          <!-- LOWER HALF: name + desc + learn more -->
          <div style="padding:1.625rem 1.75rem;flex:1;display:flex;flex-direction:column;gap:.75rem;">
            <h3 style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1.125rem;letter-spacing:-.01em;line-height:1.2;margin:0;">{s.name}</h3>
            <p style="font-size:.8125rem;line-height:1.75;opacity:.65;margin:0;font-family:Inter,sans-serif;flex:1;">{s.desc}</p>
            <div class="svc-link" style="font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;font-family:Inter,sans-serif;font-weight:600;display:flex;align-items:center;gap:.4rem;opacity:.7;transition:opacity .2s;">
              Learn more
              <span class="svc-arrow" style="display:inline-block;transition:transform .2s;">↗</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Mobile: 1-col, tablet: 2-col via media query in style tag below -->
  </div>
</section>

<style>
  @media (max-width: 900px) {
    #services > div > div:last-child {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
  @media (max-width: 560px) {
    #services > div > div:last-child {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<script>
  document.querySelectorAll('.svc-card').forEach(card => {
    const el      = card as HTMLElement;
    const hBg     = el.dataset.hoverBg    ?? '#FF3B00';
    const hTxt    = el.dataset.hoverText  ?? '#fff';
    const dBg     = el.dataset.defaultBg  ?? '#141414';
    const dTxt    = el.dataset.defaultText ?? '#F5F5F0';
    const overlay = el.querySelector('.svc-overlay') as HTMLElement;
    const img     = el.querySelector('.svc-img') as HTMLElement;
    const link    = el.querySelector('.svc-link') as HTMLElement;
    const arrow   = el.querySelector('.svc-arrow') as HTMLElement;

    el.addEventListener('mouseenter', () => {
      el.style.background   = hBg;
      el.style.color        = hTxt;
      el.style.transform    = 'translateY(-6px)';
      el.style.boxShadow    = '0 24px 64px rgba(0,0,0,0.35)';
      if (overlay) overlay.style.background = 'rgba(255,59,0,0.18)';
      if (img)     img.style.transform      = 'scale(1.06)';
      if (link)    link.style.opacity       = '1';
      if (arrow)   arrow.style.transform    = 'translate(3px,-3px)';
    });

    el.addEventListener('mouseleave', () => {
      el.style.background   = dBg;
      el.style.color        = dTxt;
      el.style.transform    = '';
      el.style.boxShadow    = '';
      if (overlay) overlay.style.background = 'rgba(255,59,0,0)';
      if (img)     img.style.transform      = '';
      if (link)    link.style.opacity       = '.7';
      if (arrow)   arrow.style.transform    = '';
    });
  });
</script>
