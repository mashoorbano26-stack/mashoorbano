---
// src/components/sections/Hero.astro
// AUDIT FIXES (keep everything, only add/correct):
//  1. Marquee ring: restored <g><animateTransform/><text><textPath></g> — was missing, ring never rendered
//  2. open() now sets clip-path to circle(150%) so fullscreen actually reveals
//  3. zoomAndOpen(): circle zooms to fill hero section → then fullscreen opens (auto-expand effect)
//  4. Tagline X/Y position from admin (tagline_offset_x / tagline_offset_y)
//  5. Arrow visible on .hero-headline hover (not just .hero-circle hover) + clean, no orange fill
//  6. All previous controls fully retained

import { getAdmin } from '@/lib/supabase';
import { loadTheme } from '@/lib/theme';
const supabaseAdmin = getAdmin(Astro.locals);
const theme = await loadTheme(supabaseAdmin);

interface HeroContent { [key: string]: string | undefined; }

let c: HeroContent = {};
try {
  const { data } = await supabaseAdmin
    .from('site_content')
    .select('content')
    .eq('page', 'home')
    .eq('section', 'hero')
    .single();
  if (data?.content) c = data.content as HeroContent;
} catch {}

// ── Video URL parser: detect YouTube / Instagram / direct file ──
function parseVideo(raw: string) {
  const url = (raw ?? '').trim();
  if (!url) return { type: 'none' as const };
  const yt = url.match(/(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([A-Za-z0-9_-]{11})/);
  if (yt) return { type: 'youtube' as const, id: yt[1] };
  const ig = url.match(/instagram\.com\/(?:p|reel|reels|tv)\/([A-Za-z0-9_-]+)/);
  if (ig) return { type: 'instagram' as const, id: ig[1] };
  return { type: 'file' as const, url };
}

const rawVideo = (c.video_url ?? '').trim() || 'https://www.w3schools.com/html/mov_bbb.mp4';
const vid = parseVideo(rawVideo);

// Embed URLs
const ytCircle = vid.type === 'youtube'
  ? `https://www.youtube.com/embed/${vid.id}?autoplay=1&mute=1&loop=1&playlist=${vid.id}&controls=0&modestbranding=1&showinfo=0&rel=0&playsinline=1&disablekb=1`
  : '';
// NOTE: mute=1 added below — browsers (and YouTube's own player) block
// unmuted autoplay unless it's the direct synchronous result of a click.
// The auto-expand zoom-then-open path runs from a setTimeout with zero
// user gesture, so without mute=1 the video loads but silently refuses
// to play, leaving it paused until manually clicked. Native controls
// (controls=1 below) still let the visitor unmute afterward.
const ytFull = vid.type === 'youtube'
  ? `https://www.youtube.com/embed/${vid.id}?autoplay=1&mute=1&loop=1&playlist=${vid.id}&controls=1&rel=0&playsinline=1`
  : '';
const igEmbed = vid.type === 'instagram'
  ? `https://www.instagram.com/reel/${vid.id}/embed`
  : '';

// ── WORD 1 ──
const word1        = c.word1            ?? 'MASHOOR';
const word1Color   = c.word1_color      ?? '#F5F5F0';
const word1Size    = c.word1_size       ?? 'clamp(2.2rem,7vw,5.5rem)';
const word1OffsetX = c.word1_offset_x   ?? '0';
const word1OffsetY = c.word1_offset_y   ?? '0';
// ── WORD 2 ──
const word2        = c.word2            ?? 'BANO';
const word2Color   = c.word2_color      ?? '#FF3B00';
const word2Size    = c.word2_size       ?? 'clamp(2.2rem,7vw,5.5rem)';
const word2OffsetX = c.word2_offset_x   ?? '0';
const word2OffsetY = c.word2_offset_y   ?? '0';
// ── CIRCLE ──
const circleSize   = c.circle_size      ?? 'clamp(150px,17vw,260px)';
const circleBorder = c.circle_border_color ?? '#FFFFFF';
// circle_border_enabled: DEFAULT NOW FLIPPED TO OFF.
// This was previously defaulting to 'true' (border ON) unless an admin
// found and unchecked a specific checkbox — meaning the orange ring kept
// showing regardless of any hover-state fix, since nothing ever disabled
// the border itself. Now it's off by default: the spinning marquee ring
// (already correctly rendering, sitting right at the video's edge) is the
// ONLY ring around the video unless this is explicitly turned back on.
const circleBorderOn = c.circle_border_enabled === 'true';
const circleBorderW= circleBorderOn ? (c.circle_border_width ?? '2') : '0';
const circleOffsetX= c.circle_offset_x  ?? '0';
const circleOffsetY= c.circle_offset_y  ?? '0';
// ── MARQUEE ──
const orbitalRaw   = c.orbital_text     ?? 'SEE MORE · SEE MORE · SEE MORE · SEE MORE ·';
const orbColor     = c.orbital_color    ?? '#FFFFFF';
const orbSize      = c.orbital_size      ?? '11';
const orbSpeed     = parseFloat(c.orbital_speed ?? '14');
const marqueeHoverScale = c.marquee_hover_scale ?? '1.5';
// orbital_opacity: resting opacity of the ring (0.1–1.0). Default 1 so the fill colour is exactly
// what the admin picks — no hidden grey wash. Lower it to create a subtle-then-bright hover effect.
const orbOpacity   = parseFloat(c.orbital_opacity ?? '1').toFixed(2);
// orbital_radius: radius of the circular text path in SVG viewBox units (viewBox is 260×260, centre 130,130).
// SVG uses inset:0 / width:100% (1 SVG unit = 1 CSS pixel for default 260px circle).
// Video border outer edge ≈ 95.6 SVG units. 98 = clean 2px gap from border (default).
const orbRadius    = Math.min(130, Math.max(50, parseInt(c.orbital_radius ?? '98')));
// Build the SVG circular path dynamically from orbRadius
const orbPath      = `M130,130 m-${orbRadius},0 a${orbRadius},${orbRadius} 0 1,1 ${orbRadius * 2},0 a${orbRadius},${orbRadius} 0 1,1 -${orbRadius * 2},0`;
// ── TAGLINE ──
const tagline      = c.tagline           ?? 'Making your BRAND Famous';
const taglineColor = c.tagline_color      ?? '#FFFFFF';
const taglineSize  = c.tagline_size       ?? 'clamp(.85rem,1.3vw,1.1rem)';
const taglineBg    = c.tagline_bg         ?? '#FF3B00';
const taglineBoxText = c.tagline_box_text ?? '#FFFFFF';
const taglineOffsetX = c.tagline_offset_x ?? '0'; // NEW: admin-controlled X position
const taglineOffsetY = c.tagline_offset_y ?? '0'; // NEW: admin-controlled Y position
// ── GENERAL ──
const wordsGap     = c.words_gap        ?? 'clamp(5rem,11vw,11rem)';
const subheadline  = c.subheadline      ?? 'Websites · Merch · Content · Meta Ads · Google Ads';
const subColor     = c.subheadline_color ?? '#FFFFFF'; // NEW: pure white by default, was riding on faded textColor before
const subOffsetX   = c.sub_offset_x     ?? '0';
const subOffsetY   = c.sub_offset_y     ?? '0';
const ctaPrimary   = c.cta_primary_label ?? 'See Packages';
const ctaSecond    = c.cta_secondary_label ?? 'Book a Free Call';
const ctaSecondBg  = c.cta_secondary_bg ?? '#FFFFFF';   // NEW: solid white box
const ctaSecondText= c.cta_secondary_text_color ?? '#000000'; // NEW: black text
const textColor    = c.text_color       ?? '#F5F5F0';
const accentColor  = c.accent_color     ?? '#FF3B00';
const bgColor      = theme.hero_bg ?? c.bg_color ?? '#0A0A0A';
const meta1        = c.meta_line1       ?? 'Digital Agency';
const meta2        = c.meta_line2       ?? "India's Bold Brands";
const meta3        = c.meta_line3       ?? 'Est. 2024';
const autoSec      = parseInt(c.auto_expand_seconds ?? '0');

// ── WhatsApp link for the secondary CTA ──
// Reuses the SAME global number set in Admin → Settings → WhatsApp Number
// (the exact field already used by Footer.astro and ContactSection.astro) —
// no duplicate data entry, single source of truth.
let waNumber = '917814718340';
try {
  const { data: settingsRow } = await supabaseAdmin
    .from('site_content')
    .select('content')
    .eq('page', 'settings')
    .eq('section', 'global')
    .single();
  if (settingsRow?.content?.whatsapp) waNumber = settingsRow.content.whatsapp;
} catch {}
const waHref = `https://wa.me/${waNumber}?text=${encodeURIComponent("Hi! I'd like to book a free call with MashoorBano.")}`;

// Marquee text: normalise separators → repeat 8× to fully fill the circle path
const orbNormalised = orbitalRaw.split(/[·.]/).map(x => x.trim()).filter(Boolean).join(' · ');
const orbText = ((orbNormalised || orbitalRaw).trim() + ' · ').repeat(8);

// Unique path ID per render (prevents SVG id collisions if component used twice)
const pid = 'op' + Math.random().toString(36).slice(2, 7);
---

<section id="hero" class="hero-section" style={`position:relative;min-height:100vh;height:100vh;overflow:hidden;background:${bgColor};`}>

  <!-- Meta labels -->
  <div style={`position:absolute;top:5.5rem;left:2rem;z-index:5;display:flex;flex-direction:column;gap:.3rem;color:${textColor};opacity:.2;font-size:.58rem;letter-spacing:.22em;text-transform:uppercase;font-family:Inter,sans-serif;`}>
    <span>{meta1}</span><span>{meta2}</span><span>{meta3}</span>
  </div>
  <div style={`position:absolute;top:5.5rem;right:2rem;z-index:5;color:${textColor};opacity:.2;font-size:.58rem;letter-spacing:.18em;font-family:Inter,sans-serif;`} data-hero-version="v2-0542">©2024 · v2-0542</div>

  <!-- CENTRED HEADLINE
       FIX: min-height added below. Without it, this flex container's height
       shrinks to fit ONLY the text (since #heroCircle is position:absolute
       and excluded from height calc) — meaning its hoverable box was shorter
       than the visually-overlapping circle/ring, causing inconsistent hover
       behaviour depending on exact cursor position. min-height:circleSize
       guarantees the hit-area matches what's actually visible. -->
  <div id="heroHeadline" class="hero-headline"
    style={`position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:10;display:flex;align-items:center;justify-content:center;width:100%;min-height:${circleSize};`}
    aria-label={`${word1} ${word2}`}>

    <div class="hero-words" style={`display:flex;align-items:center;justify-content:center;gap:${wordsGap};`}>
      <span class="hero-word" style={`font-family:'Space Grotesk',sans-serif;font-weight:900;color:${word1Color};font-size:${word1Size};letter-spacing:-0.04em;line-height:1;white-space:nowrap;transform:translate(${word1OffsetX}px,${word1OffsetY}px);`}>{word1}</span>
      <span class="hero-word" style={`font-family:'Space Grotesk',sans-serif;font-weight:900;color:${word2Color};font-size:${word2Size};letter-spacing:-0.04em;line-height:1;white-space:nowrap;transform:translate(${word2OffsetX}px,${word2OffsetY}px);`}>{word2}</span>
    </div>

    <!-- CIRCLE -->
    <div id="heroCircle" class="hero-circle"
      style={`position:absolute;top:50%;left:50%;transform:translate(calc(-50% + ${circleOffsetX}px),calc(-50% + ${circleOffsetY}px));z-index:15;width:${circleSize};height:${circleSize};cursor:pointer;`}
      role="button" tabindex="0" aria-label="Play video fullscreen" title="Click to play video">

        <!-- ═══════════════════════════════════════════════════════════
           MARQUEE RING — seamless infinite spin via animateTransform
           rotating the WHOLE <g> group 360° around the SVG centre.

           SVG is inset:0/width:100% → 1 SVG unit = 1 CSS pixel.
           Video inset:14% → video border outer edge ≈ 95.6 SVG units.
           orbital_radius default 98 = 2px gap from the video border.

           opacity = orbital_opacity (admin, default 1.0).
           Setting colour to #FFFFFF in admin → actually white (no grey wash).
           CSS hover forces opacity:1 and scales the ring.
           ═══════════════════════════════════════════════════════════ -->
      <svg
        class="hero-ring"
        viewBox="0 0 260 260"
        xmlns="http://www.w3.org/2000/svg"
        style={`position:absolute;inset:0;width:100%;height:100%;overflow:visible;opacity:${orbOpacity};transition:opacity .4s ease,transform .4s ease;--hscale:${marqueeHoverScale};pointer-events:none;`}
        aria-hidden="true"
      >
        <defs>
          <!-- Circular path radius = orbital_radius admin field (default 104 in 260-unit viewBox) -->
          <path id={pid} d={orbPath} fill="none"/>
        </defs>

        <!-- Spinning text group — animateTransform rotates 360° seamlessly, no jump -->
        <g>
          <animateTransform
            attributeName="transform"
            type="rotate"
            from="0 130 130"
            to="360 130 130"
            dur={`${orbSpeed}s`}
            repeatCount="indefinite"
          />
          <text
            font-size={orbSize}
            fill={orbColor}
            font-family="Space Grotesk,Inter,sans-serif"
            letter-spacing="0.07em"
          >
            <textPath href={`#${pid}`} startOffset="0%">{orbText}</textPath>
          </text>
        </g>
      </svg>

      <!-- VIDEO inside circle: file / youtube / instagram.
           class="hero-video-frame" lets the hover CSS below force this border
           to pure white on hover — regardless of whatever colour is set at rest —
           so hovering always reads as "white ring", matching the marquee. -->
      <div class="hero-video-frame" style={`position:absolute;inset:14%;border-radius:50%;overflow:hidden;border:${circleBorderW}px solid ${circleBorder};background:#000;transition:border-color .4s ease;`}>
        {vid.type === 'file' && (
          <video id="heroCircleVid" style="width:100%;height:100%;object-fit:cover;display:block;" src={vid.url} autoplay muted loop playsinline preload="auto"/>
        )}
        {vid.type === 'youtube' && (
          <iframe
            src={ytCircle}
            style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:178%;height:178%;border:0;pointer-events:none;"
            allow="autoplay; encrypted-media" loading="lazy" title="Hero video"></iframe>
        )}
        {vid.type === 'instagram' && (
          <iframe
            src={igEmbed}
            style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:140%;height:160%;border:0;pointer-events:none;"
            allow="autoplay; encrypted-media" loading="lazy" title="Hero video"></iframe>
        )}
      </div>

      <!-- HOVER ARROW — just the SVG arrow, no filled background.
           The MOVING MARQUEE RING above is what "encircles" it.
           Visible on both .hero-circle hover AND .hero-headline hover (see CSS). -->
      <div id="heroArrow"
        style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) scale(.6);opacity:0;transition:opacity .25s,transform .25s;pointer-events:none;z-index:18;">
        <div style="width:clamp(44px,5vw,64px);height:clamp(44px,5vw,64px);display:flex;align-items:center;justify-content:center;">
          <svg width="100%" height="100%" viewBox="0 0 40 40" fill="none" aria-hidden="true">
            <path d="M13 27 L27 13 M27 13 H17 M27 13 V23" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
    </div>

  </div>

  <!-- ══════════════════════════════════════════════════════════════
       TAGLINE — independently positioned absolute element.
       Sits just below the circle by default (top:50% + circleRadius).
       tagline_offset_x shifts it left/right from horizontal centre.
       tagline_offset_y shifts it up/down from the default below-circle position.
       Both are admin-controlled with full range.
       ══════════════════════════════════════════════════════════════ -->
  <div
    id="heroTagline"
    style={`
      position:absolute;
      top:50%;
      left:50%;
      z-index:12;
      transform: translate(
        calc(-50% + ${taglineOffsetX}px),
        calc(clamp(80px,9.5vw,140px) + ${taglineOffsetY}px)
      );
      text-align:center;
      pointer-events:none;
    `}
  >
    <span style={`
      display:inline-block;
      background:${taglineBg};
      color:${taglineBoxText};
      font-size:${taglineSize};
      font-family:'Space Grotesk',sans-serif;
      font-weight:700;
      letter-spacing:.05em;
      padding:.4rem 1.2rem;
      border-radius:8px;
      line-height:1.3;
      text-transform:uppercase;
      white-space:nowrap;
    `}>{tagline}</span>
  </div>

  <!-- Subheadline (X/Y placement) + CTAs — tagline is now separate above -->
  <div style={`position:absolute;bottom:clamp(2.5rem,10vh,6rem);left:50%;transform:translateX(-50%);z-index:10;display:flex;flex-direction:column;align-items:center;gap:1.4rem;width:100%;padding:0 2rem;text-align:center;`}>
    <p style={`color:${subColor};opacity:1;font-size:clamp(.6rem,1vw,.8125rem);letter-spacing:.18em;text-transform:uppercase;font-family:Inter,sans-serif;margin:0;line-height:1.9;transform:translate(${subOffsetX}px,${subOffsetY}px);`}>{subheadline}</p>
    <div style={`width:1px;height:30px;background:linear-gradient(to bottom,${accentColor},transparent);opacity:.6;`}></div>
    <div style="display:flex;align-items:center;gap:.875rem;flex-wrap:wrap;justify-content:center;">
      <a href="#packages" style={`padding:.75rem 1.875rem;background:${accentColor};color:#fff;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;text-decoration:none;display:inline-block;transition:opacity .2s;`} onmouseover="this.style.opacity='.82'" onmouseout="this.style.opacity='1'">{ctaPrimary}</a>
      <a href={waHref} target="_blank" rel="noopener" style={`padding:.75rem 1.875rem;background:${ctaSecondBg};color:${ctaSecondText};border:1.5px solid ${ctaSecondBg};font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;text-decoration:none;display:inline-block;transition:opacity .2s;`} onmouseover="this.style.opacity='.85'" onmouseout="this.style.opacity='1'">{ctaSecond}</a>
    </div>
  </div>

  <!-- Scroll indicator — bouncing text + animated descending line -->
  <div
    style="position:absolute;bottom:1.75rem;left:50%;transform:translateX(-50%);
      z-index:10;display:flex;flex-direction:column;align-items:center;gap:.4rem;
      animation:heroBounce 2.2s ease-in-out infinite;"
    aria-hidden="true"
  >
    <span style="font-family:Inter,sans-serif;font-size:.5rem;letter-spacing:.28em;
      text-transform:uppercase;color:#fff;opacity:.35;">Scroll</span>
    <div style="width:1px;height:32px;
      background:linear-gradient(to bottom,rgba(255,255,255,.5),transparent);
      animation:heroLineDrop 2.2s ease-in-out infinite;"></div>
  </div>

  <!-- Fullscreen overlay — clip-path expands from centre on open() -->
  <div id="heroFullscreen"
    style="position:absolute;inset:0;z-index:200;background:#000;display:flex;align-items:center;justify-content:center;
      opacity:0;pointer-events:none;
      clip-path:circle(0% at 50% 50%);
      transition:clip-path .65s cubic-bezier(.4,0,.2,1), opacity .15s ease;"
    aria-modal="true" role="dialog" aria-label="Fullscreen video">
    <div id="heroFullInner" style="width:100%;height:100%;"></div>
    <button id="heroCloseBtn" aria-label="Close video"
      style="position:absolute;top:1.25rem;right:1.25rem;width:44px;height:44px;border-radius:50%;background:rgba(0,0,0,.65);border:1.5px solid rgba(255,255,255,.2);color:#fff;font-size:1.125rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s;z-index:201;"
      onmouseover="this.style.background='#FF3B00';this.style.borderColor='#FF3B00'"
      onmouseout="this.style.background='rgba(0,0,0,.65)';this.style.borderColor='rgba(255,255,255,.2)'">✕</button>
  </div>

</section>

<style>
  /* ── Hover: ring brightens AND scales when hovering the headline text ──
     ROOT FIX #1: previously only set opacity, not transform.
     Without scale() the ring stayed tight around the video (looked like a plain circle).
     ROOT FIX #2: .is-active is toggled by JS on #heroHeadline mouseenter/mouseleave
     (see script below) — a deterministic backup that doesn't depend on the exact
     box geometry of nested :hover across absolutely-positioned elements.        */
  .hero-headline:hover .hero-ring,
  #heroCircle.is-active .hero-ring {
    opacity: 1 !important;
    transform: scale(var(--hscale, 1.5)) !important;
  }

  /* ── Hover: ring scales + arrow appears when hovering directly on the circle ── */
  .hero-circle:hover .hero-ring,
  .hero-circle:focus .hero-ring {
    opacity: 1 !important;
    transform: scale(var(--hscale, 1.5)) !important;
  }

  /* ── Arrow appears on BOTH headline hover AND direct circle hover ──
     Shows the white SVG arrow in circle centre, no filled background,
     encircled by the now-scaled marquee ring above.                    */
  .hero-headline:hover #heroArrow,
  .hero-circle:hover #heroArrow,
  .hero-circle:focus #heroArrow,
  #heroCircle.is-active #heroArrow {
    opacity: 1 !important;
    transform: translate(-50%, -50%) scale(1) !important;
  }

  /* ── Hover: video border forced to pure white, synced with marquee ──
     ROOT FIX for "orange circle on hover": the static video border
     (circle_border_color, set independently in admin) never had any
     hover behaviour before — so no matter what the marquee colour was
     set to, that solid border stayed exactly as visible, looking like
     "still an orange circle." Now hovering forces it to white too, so
     border + spinning marquee read as ONE unified white ring.
     #heroCircle.is-active is the JS-driven deterministic backup.       */
  .hero-headline:hover .hero-video-frame,
  .hero-circle:hover .hero-video-frame,
  .hero-circle:focus .hero-video-frame,
  #heroCircle.is-active .hero-video-frame {
    border-color: #fff !important;
  }

  @media (max-width: 640px) {
    .hero-headline { position: absolute !important; flex-direction: column !important; }
    .hero-words    { flex-direction: column !important; gap: clamp(5.5rem, 30vw, 9rem) !important; }
    .hero-word     { font-size: clamp(2rem, 11vw, 3rem) !important; text-align: center !important; }
    .hero-circle   { width: clamp(120px, 34vw, 160px) !important; height: clamp(120px, 34vw, 160px) !important; }
  }

  @keyframes heroBounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(7px); }
  }
  @keyframes heroLineDrop {
    0%   { transform: scaleY(0); transform-origin: top;    opacity: 0; }
    30%  { transform: scaleY(1); transform-origin: top;    opacity: 1; }
    70%  { transform: scaleY(1); transform-origin: bottom; opacity: 1; }
    100% { transform: scaleY(0); transform-origin: bottom; opacity: 0; }
  }
</style>

<script define:vars={{
  autoSec,
  vidType:   vid.type,
  fileUrl:   vid.type === 'file' ? vid.url : '',
  ytFull,
  igEmbed,
  circleOffX: circleOffsetX,
  circleOffY: circleOffsetY,
  ringRestOpacity: orbOpacity,
  hoverScale: marqueeHoverScale,
  borderRestColor: circleBorder
}}>
(function () {
  const circle     = document.getElementById('heroCircle');
  const headline   = document.getElementById('heroHeadline');
  const fullscreen = document.getElementById('heroFullscreen');
  const inner      = document.getElementById('heroFullInner');
  const closeBtn   = document.getElementById('heroCloseBtn');
  if (!circle || !fullscreen || !inner || !closeBtn) return;

  /* ── Build fullscreen video HTML ──
     muted added on the file-video path below: same browser autoplay-policy
     reason as the YouTube mute=1 fix above. Native controls let the
     visitor unmute manually once it's playing.                          */
  function buildFull() {
    if (vidType === 'file') {
      return `<video src="${fileUrl}" style="width:100%;height:100%;object-fit:cover;display:block;" autoplay muted loop playsinline controls></video>`;
    }
    if (vidType === 'youtube') {
      return `<iframe src="${ytFull}" style="width:100%;height:100%;border:0;" allow="autoplay; encrypted-media; fullscreen" allowfullscreen></iframe>`;
    }
    if (vidType === 'instagram') {
      return `<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;"><iframe src="${igEmbed}" style="width:min(420px,90vw);height:min(720px,90vh);border:0;" allow="autoplay; encrypted-media"></iframe></div>`;
    }
    return '';
  }

  /* ── Open fullscreen (clip-path expands from 0% → 150%) ── */
  function open() {
    inner.innerHTML = buildFull();
    // FIXED: must set clip-path here so the transition actually plays
    fullscreen.style.clipPath   = 'circle(150% at 50% 50%)';
    fullscreen.style.opacity    = '1';
    fullscreen.style.pointerEvents = 'auto';
    document.body.style.overflow = 'hidden';

    // BELT-AND-SUSPENDERS: explicitly call .play() on the inserted video.
    // The `autoplay` attribute on a <video> created via innerHTML doesn't
    // always reliably fire in every browser the way it does for markup
    // present in the initial page load — calling .play() directly removes
    // that ambiguity. Wrapped in .catch() since some browsers return a
    // rejected promise harmlessly if playback was already starting.
    if (vidType === 'file') {
      const vEl = inner.querySelector('video');
      if (vEl) vEl.play().catch(() => {});
    }
  }

  /* ── Close fullscreen (clip-path collapses back to 0%) ── */
  function close() {
    fullscreen.style.clipPath = 'circle(0% at 50% 50%)';
    fullscreen.style.opacity  = '0';
    setTimeout(() => {
      fullscreen.style.pointerEvents = 'none';
      inner.innerHTML = '';
    }, 650);
    document.body.style.overflow = '';
  }

  /* ── Auto-expand: zoom circle to fill hero → then open fullscreen ──
     After auto_expand_seconds the video circle animates to cover the
     entire hero section (zoom-in effect), then the fullscreen overlay
     opens behind it. Gives a cinematic "push-through" feel.           */
  function zoomAndOpen() {
    const heroSec = document.getElementById('hero');
    if (!heroSec) { open(); return; }

    const cRect = circle.getBoundingClientRect();
    const hRect = heroSec.getBoundingClientRect();

    // Scale needed to fill the hero section (add 20% extra to avoid gaps)
    const scale = Math.max(hRect.width / cRect.width, hRect.height / cRect.height) * 1.2;

    // Animate the circle zooming to fill the hero section
    circle.style.transition = 'transform 1.4s cubic-bezier(.16,1,.3,1)';
    circle.style.zIndex     = '190';
    circle.style.transform  =
      `translate(calc(-50% + ${circleOffX}px), calc(-50% + ${circleOffY}px)) scale(${scale})`;

    // After zoom completes, open the fullscreen overlay
    const t1 = setTimeout(() => {
      open();

      // Reset circle while hidden behind the fullscreen overlay
      const t2 = setTimeout(() => {
        circle.style.transition = 'none';
        circle.style.transform  =
          `translate(calc(-50% + ${circleOffX}px), calc(-50% + ${circleOffY}px))`;
        circle.style.zIndex = '15';

        // Restore natural transitions after the DOM settles
        requestAnimationFrame(() => requestAnimationFrame(() => {
          circle.style.transition = '';
        }));
      }, 120);

      closeBtn.addEventListener('click', () => clearTimeout(t2), { once: true });
    }, 1420);

    closeBtn.addEventListener('click', () => clearTimeout(t1), { once: true });
  }

  /* ── Event wiring ── */
  circle.addEventListener('click', open);
  circle.addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(); }
  });
  closeBtn.addEventListener('click', close);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });

  /* ── Hover state: DIRECT JS style control, not dependent on CSS at all ──
     Earlier attempts relied on nested CSS :hover / .is-active class
     selectors. Those should work, but since the reported symptom
     (static border staying orange on hover) persisted, this removes
     ALL dependency on CSS cascade/specificity/Astro-scoping behaviour
     entirely: JS grabs the three actual elements and sets their inline
     styles directly on activate, then restores the exact admin-configured
     resting values on deactivate (not just clearing the style, which
     would have reset the ring to default opacity 1 instead of whatever
     was configured in admin). The CSS rules from before are left in
     place as a harmless redundant fallback — they just won't be doing
     the real work anymore.                                              */
  const ring       = circle.querySelector('.hero-ring');
  const videoFrame = circle.querySelector('.hero-video-frame');
  const arrow      = document.getElementById('heroArrow');

  if (headline) {
    const activate = () => {
      circle.classList.add('is-active');
      if (ring)       { ring.style.opacity = '1'; ring.style.transform = `scale(${hoverScale})`; }
      if (videoFrame) { videoFrame.style.borderColor = '#ffffff'; }
      if (arrow)      { arrow.style.opacity = '1'; arrow.style.transform = 'translate(-50%,-50%) scale(1)'; }
    };
    const deactivate = () => {
      circle.classList.remove('is-active');
      if (ring)       { ring.style.opacity = String(ringRestOpacity); ring.style.transform = ''; }
      if (videoFrame) { videoFrame.style.borderColor = borderRestColor; }
      if (arrow)      { arrow.style.opacity = '0'; arrow.style.transform = 'translate(-50%,-50%) scale(.6)'; }
    };
    headline.addEventListener('mouseenter', activate);
    headline.addEventListener('mouseleave', deactivate);
    headline.addEventListener('focusin', activate);
    headline.addEventListener('focusout', deactivate);
  }

  /* ── Auto-expand timer ── */
  if (autoSec > 0) {
    const t = setTimeout(() => {
      if (!fullscreen.style.opacity || fullscreen.style.opacity === '0') {
        zoomAndOpen(); // zoom → then fullscreen (not just open())
      }
    }, autoSec * 1000);

    closeBtn.addEventListener('click', () => clearTimeout(t), { once: true });

    // Cancel only if user scrolls more than 150px (ignore tiny load-time scrolls)
    const onScroll = () => {
      if (window.scrollY > 150) { clearTimeout(t); window.removeEventListener('scroll', onScroll); }
    };
    window.addEventListener('scroll', onScroll);
  }
})();
</script>
