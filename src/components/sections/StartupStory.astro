---
// src/components/sections/StartupStory.astro
// AUDIT FIXES:
//  1. Stats now read from admin panel (stat1_num/stat1_label … stat4_num/stat4_label)
//     with hardcoded fallbacks so site renders even if CMS is empty.
//  2. Founder video (video_url from admin/story) shown on RIGHT column, above stats.
//  3. All previous layout, reveal animations, and colour controls retained.
import { getAdmin } from '@/lib/supabase';
import { loadTheme } from '@/lib/theme';
const supabaseAdmin = getAdmin(Astro.locals);
const theme = await loadTheme(supabaseAdmin);

interface StoryContent {
  section_label?: string;
  headline?:      string;
  body?:          string;
  pull_quote?:    string;
  author?:        string;
  author_role?:   string;
  photo_url?:     string | null;
  video_url?:     string | null;
  // admin-controlled stats
  stat1_num?:     string;
  stat1_label?:   string;
  stat2_num?:     string;
  stat2_label?:   string;
  stat3_num?:     string;
  stat3_label?:   string;
  stat4_num?:     string;
  stat4_label?:   string;
  // colours
  bg_color?:      string;
  text_color?:    string;
  heading_color?: string;
  accent_color?:  string;
}

let story: StoryContent = {};
try {
  const { data } = await supabaseAdmin
    .from('site_content')
    .select('content')
    .eq('page', 'home')
    .eq('section', 'story')
    .single();
  if (data?.content) story = data.content as StoryContent;
} catch {}

// ── Colours ──
const storyBg      = theme.story_bg   ?? story.bg_color      ?? '#0A0A0A';
const storyText    = theme.story_text ?? story.text_color     ?? '#F5F5F0';
const accentColor  =                     story.accent_color   ?? '#FF3B00';

// ── Content ──
const sectionLabel = story.section_label ?? '03 — Our story';
const pullQuote    = story.pull_quote    ?? 'Your brand deserves better than templates and jargon.';
const body         = story.body         ?? 'We got tired of agencies that charged a fortune and delivered generic. Every brand we met was paying lakhs for cookie-cutter websites and ads that burned budget without results.\n\nSo we built Mashurban — a studio that does everything a growing brand needs, without the fluff. One team, one roof, one goal: make your brand actually work.\n\nWe\'re builders, not account managers. We obsess over your numbers the same way we obsess over ours.';
const author       = story.author       ?? 'Founder, Mashurban';
const authorRole   = story.author_role  ?? 'Builder · Designer · Strategist';
const paragraphs   = body.split('\n\n').filter(Boolean);

// ── Stats: read from admin with hardcoded fallbacks ──
const stats = [
  { num: story.stat1_num   ?? '25+',   label: story.stat1_label   ?? 'Brands Built'        },
  { num: story.stat2_num   ?? '₹50L+', label: story.stat2_label   ?? 'Ad Spend Managed'    },
  { num: story.stat3_num   ?? '3×',    label: story.stat3_label   ?? 'Average ROAS'         },
  { num: story.stat4_num   ?? '8',     label: story.stat4_label   ?? 'Cities Served'        },
];

// ── Video: detect type so we can render correctly ──
function getVideoType(url: string | null | undefined) {
  if (!url?.trim()) return null;
  if (/youtube\.com|youtu\.be/.test(url)) return 'youtube';
  if (/vimeo\.com/.test(url))             return 'vimeo';
  if (/instagram\.com/.test(url))         return 'instagram';
  if (/embed/.test(url))                  return 'embed';
  return 'file';
}

const videoType = getVideoType(story.video_url);

// Build embed URL for YouTube links (convert watch?v= → embed/)
function buildEmbedUrl(url: string, type: string): string {
  if (type === 'youtube') {
    const m = url.match(/(?:watch\?v=|youtu\.be\/)([A-Za-z0-9_-]{11})/);
    if (m) return `https://www.youtube.com/embed/${m[1]}?autoplay=0&rel=0&modestbranding=1`;
  }
  return url;
}
const embedUrl = story.video_url && videoType && videoType !== 'file'
  ? buildEmbedUrl(story.video_url, videoType)
  : story.video_url;
---

<section id="story" class="py-24 px-6 md:px-12" style={`background:${storyBg};color:${storyText};`}>
  <div class="max-w-7xl mx-auto">

    <div class="section-label reveal" style="font-size:.65rem;letter-spacing:.22em;text-transform:uppercase;opacity:.4;margin-bottom:3rem;display:flex;align-items:center;gap:1rem;">
      <span>{sectionLabel}</span>
      <div style="flex:1;height:1px;background:currentColor;opacity:.3;"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- ── LEFT: pull quote + body ── -->
      <div class="reveal">
        <blockquote style={`font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:clamp(28px,4vw,52px);line-height:1.1;color:#F5F5F0;margin-bottom:2.5rem;`}>
          "{pullQuote}"
        </blockquote>
        <div style="display:flex;flex-direction:column;gap:1.25rem;font-size:1rem;color:#B0B0B0;line-height:1.85;">
          {paragraphs.map(p => <p>{p}</p>)}
        </div>
      </div>

      <!-- ── RIGHT: founder video (if set) + stats + author ── -->
      <div class="reveal reveal-delay-2">

        <!-- FOUNDER VIDEO — shown when video_url is set in admin/story ── -->
        {videoType && story.video_url && (
          <div style="border-radius:16px;overflow:hidden;margin-bottom:2rem;border:1px solid rgba(255,255,255,0.08);aspect-ratio:16/9;background:#111;">
            {videoType === 'file' ? (
              <video
                src={story.video_url}
                style="width:100%;height:100%;object-fit:cover;display:block;"
                autoplay
                muted
                loop
                playsinline
                controls
              ></video>
            ) : (
              <iframe
                src={embedUrl ?? ''}
                style="width:100%;height:100%;border:0;display:block;"
                allow="autoplay; encrypted-media; fullscreen"
                allowfullscreen
                loading="lazy"
                title="Founder video"
              ></iframe>
            )}
          </div>
        )}

        <!-- STATS GRID — values from admin panel ── -->
        <div class="grid grid-cols-2 gap-6 mb-10">
          {stats.map(stat => (
            <div style="background:#1a1a1a;border-radius:16px;padding:1.5rem;border:1px solid rgba(255,255,255,0.08);">
              <div style={`font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:2.25rem;color:${accentColor};line-height:1;`}>{stat.num}</div>
              <div style="font-size:.6875rem;letter-spacing:.12em;text-transform:uppercase;color:#888;margin-top:.5rem;">{stat.label}</div>
            </div>
          ))}
        </div>

        <!-- AUTHOR ── -->
        <div style="display:flex;align-items:center;gap:1rem;border-top:1px solid rgba(255,255,255,0.08);padding-top:1.5rem;">
          {story.photo_url ? (
            <img
              src={story.photo_url}
              alt={author}
              style={`width:3rem;height:3rem;border-radius:50%;object-fit:cover;border:2px solid ${accentColor};flex-shrink:0;`}
            />
          ) : (
            <div style={`width:3rem;height:3rem;border-radius:50%;background:${accentColor};display:flex;align-items:center;justify-content:center;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1.125rem;color:#fff;flex-shrink:0;`}>
              M
            </div>
          )}
          <div>
            <div style="font-size:.875rem;font-weight:700;color:#F5F5F0;">{author}</div>
            <div style="font-size:.6875rem;letter-spacing:.1em;text-transform:uppercase;color:#888;margin-top:.2rem;">{authorRole}</div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
