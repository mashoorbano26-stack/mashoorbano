---
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);

const [storyRes, themeRes] = await Promise.all([
  supabase.from('site_content').select('content').eq('page','home').eq('section','story').single(),
  supabase.from('site_content').select('content').eq('page','settings').eq('section','theme').single(),
]);

const story = storyRes.data?.content ?? {};
const theme = themeRes.data?.content ?? {};

const sectionBg    = theme.story_bg      || '#111111';
const cardBg       = theme.story_card_bg || '#1A1A1A';
const headingColor = theme.story_heading || '#F5F5F0';
const textColor    = theme.story_text    || '#AAAAAA';
const accent       = theme.accent        || '#FF3B00';

const sectionLabel = story.section_label || 'Our story';
const headline     = story.headline      || 'Built by builders,\nnot account managers.';
const subheadline  = story.subheadline   || 'We got tired of agencies that charged a fortune and delivered generic.';
const body         = story.body          || 'Every brand we met was paying lakhs for cookie-cutter websites and ads that burned budget without results.\n\nSo we built Mashurban — a studio that does everything a growing brand needs, without the fluff. One team, one roof, one goal: make your brand actually work.\n\nWe obsess over your numbers the same way we obsess over ours.';
const pullQuote    = story.pull_quote    || 'Your brand deserves better than templates and jargon.';
const author       = story.author        || 'Founder, Mashurban';
const videoUrl     = story.video_url     || null;
const photoUrl     = story.photo_url     || null;

const headlineLines = headline.split('\n');

function getVideoEmbed(url) {
  if (!url) return { type: null, src: '' };
  if (url.includes('youtube.com') || url.includes('youtu.be')) {
    const match = url.match(/(?:v=|youtu\.be\/)([^&\s]+)/);
    return { type: 'iframe', src: `https://www.youtube.com/embed/${match?.[1] ?? ''}?rel=0&modestbranding=1` };
  }
  if (url.includes('vimeo.com')) {
    const match = url.match(/vimeo\.com\/(\d+)/);
    return { type: 'iframe', src: `https://player.vimeo.com/video/${match?.[1] ?? ''}?title=0&byline=0` };
  }
  return { type: 'video', src: url };
}

const videoEmbed = getVideoEmbed(videoUrl);
const bodyParagraphs = body.split('\n\n').filter(Boolean);
---

<section class="py-24 md:py-32 px-4" style={`background-color: ${sectionBg};`}>
  <div class="max-w-7xl mx-auto">

    <div class="text-center mb-16 md:mb-20">
      <span
        class="inline-block text-xs font-heading font-bold tracking-[0.25em] uppercase mb-4 px-3 py-1 rounded-full border"
        style={`color: ${accent}; border-color: ${accent}33; background: ${accent}11;`}
      >
        {sectionLabel}
      </span>
      <h2
        class="font-heading font-black leading-[0.95] tracking-tight mb-4"
        style={`color: ${headingColor}; font-size: clamp(2.8rem, 7vw, 6rem);`}
      >
        {headlineLines.map((line, i) => (
          <span class="block">
            {i === 1 ? <span style={`color: ${accent};`}>{line}</span> : line}
          </span>
        ))}
      </h2>
      <p class="text-lg md:text-xl max-w-2xl mx-auto font-body" style={`color: ${textColor};`}>
        {subheadline}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <div class="space-y-8">
        <div class="space-y-5">
          {bodyParagraphs.map((para) => (
            <p class="text-base md:text-lg leading-relaxed font-body" style={`color: ${textColor};`}>{para}</p>
          ))}
        </div>
        <blockquote
          class="relative pl-6 py-4 rounded-2xl"
          style={`border-left: 3px solid ${accent}; background: ${cardBg};`}
        >
          <p class="font-heading font-bold text-xl md:text-2xl leading-snug mb-3" style={`color: ${headingColor};`}>
            "{pullQuote}"
          </p>
          <cite class="text-sm font-body not-italic" style={`color: ${accent};`}>— {author}</cite>
        </blockquote>
      </div>

      <div class="relative">
        {videoUrl ? (
          <div class="relative rounded-3xl overflow-hidden aspect-video" style={`background: ${cardBg};`}>
            {videoEmbed.type === 'iframe' ? (
              <iframe
                src={videoEmbed.src}
                class="w-full h-full"
                title="Founder video"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            ) : (
              <video src={videoEmbed.src} class="w-full h-full object-cover" controls preload="metadata"></video>
            )}
            <div class="absolute -inset-1 rounded-3xl -z-10 blur-2xl opacity-30" style={`background: ${accent};`} aria-hidden="true"></div>
          </div>
        ) : (
          <div class="rounded-3xl aspect-video flex flex-col items-center justify-center gap-4 border border-dashed" style={`background: ${cardBg}; border-color: #2A2A2A;`}>
            <div class="w-16 h-16 rounded-full flex items-center justify-center" style={`background: ${accent}22;`}>
              <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" style={`color: ${accent};`}>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.069A1 1 0 0121 8.867v6.266a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
            </div>
            <div class="text-center">
              <p class="font-heading font-bold text-sm" style={`color: ${headingColor};`}>No founder video yet</p>
              <p class="text-xs mt-1" style={`color: ${textColor};`}>Upload from Admin → Story</p>
            </div>
          </div>
        )}

        <div class="absolute -bottom-6 -left-6 px-5 py-4 rounded-2xl shadow-2xl hidden md:block" style={`background: ${cardBg}; border: 1px solid #2A2A2A;`}>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full overflow-hidden flex-shrink-0" style={`background: ${accent}22;`}>
              {photoUrl ? (
                <img src={photoUrl} alt={author} class="w-full h-full object-cover" />
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" style={`color: ${accent};`}>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                  </svg>
                </div>
              )}
            </div>
            <div>
              <p class="font-heading font-bold text-sm" style={`color: ${headingColor};`}>{author}</p>
              <p class="text-xs" style={`color: ${textColor};`}>Mashurban</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
