---
// src/components/sections/StartupStory.astro
// Fetches from site_content (page=home, section=story) — editable from admin panel.
import { getAdmin } from '@/lib/supabase';
const supabaseAdmin = getAdmin(Astro.locals);

interface StoryContent {
  headline?: string;
  body?: string;
  pull_quote?: string;
  author?: string;
  photo_url?: string | null;
  video_url?: string | null;
}

let story: StoryContent = {};
try {
  const { data } = await supabaseAdmin
    .from('site_content')
    .select('content')
    .eq('page', 'home')
    .eq('section', 'story')
    .single();
  if (data?.content) story = data.content as StoryContent;
} catch {}

const headline   = story.headline   ?? 'Why Mashurban exists';
const body       = story.body       ?? 'We got tired of agencies that charged a fortune and delivered generic. Every brand we met was paying lakhs for cookie-cutter websites and ads that burned budget without results.\n\nSo we built Mashurban — a studio that does everything a growing brand needs, without the fluff. One team, one roof, one goal: make your brand actually work.\n\nWe\'re builders, not account managers. We obsess over your numbers the same way we obsess over ours.';
const pullQuote  = story.pull_quote ?? 'Your brand deserves better than templates and jargon.';
const author     = story.author     ?? 'Founder, Mashurban';
const paragraphs = body.split('\n\n').filter(Boolean);
---

<section id="story" class="bg-white py-24 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="section-label reveal">03 — Our story</div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <!-- Left: pull quote + body -->
      <div class="reveal">
        <blockquote class="font-heading font-bold text-[clamp(28px,4vw,52px)] leading-[1.1] text-[#1A1A1A] mb-10">
          "{pullQuote}"
        </blockquote>
        <div class="space-y-5 text-base text-[#555] leading-[1.85]">
          {paragraphs.map(p => <p>{p}</p>)}
        </div>
      </div>

      <!-- Right: stats + author -->
      <div class="reveal reveal-delay-2">
        <div class="grid grid-cols-2 gap-6 mb-10">
          {[
            { num: '25+',   label: 'Brands Built' },
            { num: '₹50L+', label: 'Ad Spend Managed' },
            { num: '3×',    label: 'Average ROAS' },
            { num: '8',     label: 'Cities Served' },
          ].map(stat => (
            <div class="bg-[#F7F5F2] rounded-2xl p-6 border border-[#E5E0D8]">
              <div class="font-heading font-bold text-4xl text-[#FF3B00] leading-none">{stat.num}</div>
              <div class="text-xs tracking-[0.12em] uppercase text-[#888] mt-2">{stat.label}</div>
            </div>
          ))}
        </div>

        <div class="flex items-center gap-4 border-t border-[#E5E0D8] pt-6">
          {story.photo_url ? (
            <img src={story.photo_url} alt={author} class="w-12 h-12 rounded-full object-cover border-2 border-[#FF3B00]" />
          ) : (
            <div class="w-12 h-12 rounded-full bg-[#FF3B00] flex items-center justify-center font-heading font-bold text-lg text-white flex-shrink-0">
              M
            </div>
          )}
          <div>
            <div class="text-sm font-bold text-[#1A1A1A]">{author}</div>
            <div class="text-xs tracking-[0.1em] uppercase text-[#888] mt-1">Builder · Designer · Strategist</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
