---
// src/components/sections/SocialProofBar.astro
// Orange background ticker bar with white scrolling text
// Text and stats managed from admin panel (site_content page=home section=stats)
import { getAdmin } from '@/lib/supabase';
const supabaseAdmin = getAdmin(Astro.locals);

interface StatsContent {
  marquee_text?: string;
  stats?: Array<{ value: string; label: string }>;
  bar_bg?: string;
  bar_text_color?: string;
  stats_bg?: string;
  stats_text_color?: string;
  stats_accent?: string;
  bar_speed?: string;
}

let cfg: StatsContent = {};
try {
  const { data } = await supabaseAdmin
    .from('site_content')
    .select('content')
    .eq('page', 'home')
    .eq('section', 'stats')
    .single();
  if (data?.content) cfg = data.content as StatsContent;
} catch {}

const marqueeText = cfg.marquee_text
  ?? '25+ Brands Built · ₹50L+ in Ad Spend Managed · Clients Across 8 Cities · Average 3× ROAS · Websites · Merch · Content · Meta Ads · Google Ads';

const stats = cfg.stats?.map(s => ({ num: s.value, label: s.label })) ?? [
  { num: '25+',  label: 'Brands Built' },
  { num: '₹50L+', label: 'Ad Spend Managed' },
  { num: '3×',   label: 'Average ROAS' },
  { num: '8',    label: 'Cities Served' },
];

// Admin-controlled colours — defaults to classic orange bar + dark stats
const barBg         = cfg.bar_bg          ?? '#FF3B00';
const barTextColor  = cfg.bar_text_color  ?? '#FFFFFF';
const statsBg       = cfg.stats_bg        ?? '#0A0A0A';
const statsText     = cfg.stats_text_color ?? '#F5F5F0';
const statsAccent   = cfg.stats_accent     ?? '#FF3B00';
const speed         = cfg.bar_speed        ?? '30';

// Repeat text enough times for seamless infinite scroll
const repeated = Array(6).fill(marqueeText).join(`  ·  `);
---

<!-- ── ORANGE TICKER BAR ── -->
<div
  style={`background:${barBg};overflow:hidden;padding:.75rem 0;position:relative;`}
  aria-label="Marquee ticker"
>
  <div
    class="ticker-track"
    style={`display:inline-flex;white-space:nowrap;animation:tickerScroll ${speed}s linear infinite;will-change:transform;`}
  >
    <!-- Two copies so the loop is seamless -->
    {[0, 1].map(() => (
      <span
        style={`display:inline-flex;align-items:center;gap:2.5rem;padding:0 2.5rem;
          font-family:'Space Grotesk',sans-serif;font-weight:700;
          font-size:clamp(.7rem,1.1vw,.875rem);
          letter-spacing:.18em;text-transform:uppercase;
          color:${barTextColor};`}
      >
        {marqueeText}
        <span style={`display:inline-block;width:6px;height:6px;border-radius:50%;background:${barTextColor};opacity:.5;flex-shrink:0;`} aria-hidden="true"></span>
      </span>
    ))}
  </div>
</div>

<!-- ── STATS GRID ── -->
<section
  id="stats"
  style={`background:${statsBg};border-bottom:1px solid rgba(255,255,255,0.06);
    padding:4rem 1.5rem;`}
>
  <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;">
    {stats.map(stat => (
      <div style={`border-top:2px solid ${statsAccent};padding-top:1.5rem;`}>
        <div style={`font-family:'Space Grotesk',sans-serif;font-weight:900;
          font-size:clamp(2rem,4vw,3rem);color:${statsText};line-height:1;margin-bottom:.4rem;`}>
          {stat.num}
        </div>
        <div style={`font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;
          color:${statsText};opacity:.45;font-family:Inter,sans-serif;`}>
          {stat.label}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  @keyframes tickerScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .ticker-track { display: inline-flex; }
  /* Pause on hover */
  .ticker-track:hover { animation-play-state: paused; }

  @media (max-width: 640px) {
    #stats > div {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
</style>
