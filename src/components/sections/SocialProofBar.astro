---
// src/components/sections/SocialProofBar.astro
// Fetches stats + marquee text from Supabase site_content (page=home, section=stats)
// Falls back to defaults if DB is unavailable
import { supabaseAdmin } from '@/lib/supabase';

interface Stat { num: string; label: string; }
interface StatsContent {
  stats?: Array<{ value: string; label: string }>;
  marquee_text?: string;
}

let statsContent: StatsContent = {};
try {
  const { data } = await supabaseAdmin
    .from('site_content')
    .select('content')
    .eq('page', 'home')
    .eq('section', 'stats')
    .single();
  if (data?.content) statsContent = data.content as StatsContent;
} catch {}

const stats: Stat[] = statsContent.stats?.map(s => ({ num: s.value, label: s.label })) ?? [
  { num: '25+',   label: 'Brands Built' },
  { num: '₹50L+', label: 'Ad Spend Managed' },
  { num: '3×',    label: 'Average ROAS' },
  { num: '8',     label: 'Cities Served' },
];

const marqueeText = statsContent.marquee_text
  ?? '25+ Brands Built · ₹50L+ in Ad Spend Managed · Clients Across 8 Cities · Average 3× ROAS';

// Duplicate marquee items for seamless loop
const marqueeItems = [marqueeText, marqueeText];
---

<!-- Marquee strip -->
<div class="bg-[#FF3B00] overflow-hidden py-3.5">
  <div class="flex whitespace-nowrap animate-marquee">
    {marqueeItems.map((text) => (
      <span class="inline-flex items-center gap-10 px-10 font-heading font-bold text-base tracking-wider text-white uppercase">
        {text}
        <span class="w-1.5 h-1.5 rounded-full bg-white/50 flex-shrink-0" aria-hidden="true"></span>
      </span>
    ))}
  </div>
</div>

<!-- Stats grid — light background -->
<section class="bg-white border-b border-[#E5E0D8] py-16 px-6 md:px-12">
  <div class="max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8">
    {stats.map(stat => (
      <div class="reveal border-t-2 border-[#FF3B00] pt-6">
        <div class="font-heading font-bold text-5xl text-[#1A1A1A]">{stat.num}</div>
        <div class="text-xs tracking-[0.14em] uppercase text-[#888] mt-2">{stat.label}</div>
      </div>
    ))}
  </div>
</section>
