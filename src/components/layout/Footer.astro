---
// src/components/layout/Footer.astro
// Fetches global settings from Supabase for email/phone/social links
import { supabaseAdmin } from '@/lib/supabase';

interface GlobalSettings {
  email?: string; phone?: string; whatsapp?: string;
  instagram_url?: string; linkedin_url?: string; youtube_url?: string;
}

let settings: GlobalSettings = {};
try {
  const { data } = await supabaseAdmin
    .from('site_content')
    .select('content')
    .eq('page', 'settings')
    .eq('section', 'global')
    .single();
  if (data?.content) settings = data.content as GlobalSettings;
} catch {}

const year      = new Date().getFullYear();
const email     = settings.email         ?? 'hello@mashurban.com';
const phone     = settings.phone         ?? '+91 78147 18340';
const whatsapp  = settings.whatsapp      ?? '917814718340';
const instagram = settings.instagram_url ?? 'https://instagram.com/mashurban';
const linkedin  = settings.linkedin_url  ?? 'https://linkedin.com/company/mashurban';
---

<footer class="bg-[#1A1A1A] text-[#CCC]">
  <div class="max-w-7xl mx-auto px-6 md:px-12 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">

      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="font-heading font-bold text-2xl text-white tracking-tight">
          Mash<span class="text-[#FF3B00]">urban</span>
        </a>
        <p class="mt-4 text-sm text-[#888] leading-relaxed">
          Brands that actually hit. Websites. Merch. Content. Ads.
        </p>
        <div class="flex gap-4 mt-6">
          <a href={instagram} target="_blank" rel="noopener" class="text-[#888] hover:text-white transition-colors text-xs tracking-widest uppercase">IG</a>
          <a href={linkedin}  target="_blank" rel="noopener" class="text-[#888] hover:text-white transition-colors text-xs tracking-widest uppercase">LI</a>
          <a href={`https://wa.me/${whatsapp}`} target="_blank" rel="noopener" class="text-[#888] hover:text-white transition-colors text-xs tracking-widest uppercase">WA</a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-xs tracking-[0.18em] uppercase text-[#666] mb-6 font-medium">Services</h4>
        <ul class="space-y-3 list-none">
          {['Website Design','Merchandise','Content Creation','Meta Ads','Google Ads','Brand Identity'].map(s => (
            <li><a href="/#services" class="text-sm text-[#888] hover:text-white transition-colors">{s}</a></li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-xs tracking-[0.18em] uppercase text-[#666] mb-6 font-medium">Company</h4>
        <ul class="space-y-3 list-none">
          {[
            { label: 'Our Story', href: '/#story' },
            { label: 'Packages',  href: '/#packages' },
            { label: 'Portfolio', href: '/#portfolio' },
            { label: 'Blog',      href: '/blog' },
            { label: 'Contact',   href: '/#contact' },
          ].map(l => (
            <li><a href={l.href} class="text-sm text-[#888] hover:text-white transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-xs tracking-[0.18em] uppercase text-[#666] mb-6 font-medium">Contact</h4>
        <ul class="space-y-3 list-none">
          <li><a href={`mailto:${email}`} class="text-sm text-[#888] hover:text-white transition-colors">{email}</a></li>
          <li><a href={`tel:${phone.replace(/\s/g,'')}`} class="text-sm text-[#888] hover:text-white transition-colors">{phone}</a></li>
          <li class="text-sm text-[#888]">India</li>
        </ul>
        <a href="/#contact" class="inline-block mt-6 text-xs font-heading font-bold tracking-widest uppercase px-6 py-3 bg-[#FF3B00] text-white hover:bg-[#e03200] transition-colors rounded-none">
          Book a Call
        </a>
      </div>
    </div>

    <div class="border-t border-[#2A2A2A] pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-[#666]">© {year} Mashurban. All rights reserved.</p>
      <div class="flex gap-8">
        <a href="/privacy" class="text-xs text-[#666] hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms"   class="text-xs text-[#666] hover:text-white transition-colors">Terms of Use</a>
        <a href="/refund"  class="text-xs text-[#666] hover:text-white transition-colors">Refund Policy</a>
      </div>
    </div>
  </div>
</footer>
